// Runtime admin API.
//
//   GET  /admin/servers
//   POST /admin/drain/<backend>/<server>
//   POST /admin/ready/<backend>/<server>
//   POST /admin/disable/<backend>/<server>   (mark DOWN)
//   POST /admin/enable/<backend>/<server>    (mark UP)
//   POST /admin/reload-servers               (reload servers_file backends)
//   GET  /readyz   readiness (any non-drained UP server)
//   GET  /livez    liveness
pack admin

struct AdminResult {
    handled: int
    status: int
    body: string
    servers: []Server
}

struct AdminStateResult {
    handled: int
    status: int
    body: string
    servers: []Server
    frontends: []Frontend
    backends: []Backend
    routes: []Route
    acls: []AclRule
}

fn path_part(path: string, idx: int) -> string {
    // path like /admin/drain/api/api1 → parts[0]="", [1]=admin, ...
    let parts = str_split(path, "/")
    // str_split("/a/b") may yield ["", "a", "b"]
    if idx < 0 {
        return ""
    }
    if idx >= len(parts) {
        return ""
    }
    return parts[idx]
}

fn admin_state_from_result(ar: AdminResult, frontends: []Frontend, backends: []Backend, routes: []Route, acls: []AclRule) -> AdminStateResult {
    return AdminStateResult {
        handled: ar.handled,
        status: ar.status,
        body: ar.body,
        servers: ar.servers,
        frontends: frontend_array_clone(frontends),
        backends: backend_array_clone(backends),
        routes: route_array_clone(routes),
        acls: acl_array_clone(acls)
    }
}

fn hex_val(c: int) -> int {
    if c >= 48 {
        if c <= 57 {
            return c - 48
        }
    }
    if c >= 65 {
        if c <= 70 {
            return c - 55
        }
    }
    if c >= 97 {
        if c <= 102 {
            return c - 87
        }
    }
    return -1
}

fn url_decode(s: string) -> string {
    let data = bytes(s)
    let mut b = str_builder()
    let mut i = 0
    while i < len(data) {
        let c = int(data[i])
        if c == 37 {
            if i + 2 < len(data) {
                let hi = hex_val(int(data[i + 1]))
                let lo = hex_val(int(data[i + 2]))
                if hi >= 0 {
                    if lo >= 0 {
                        builder_write_byte(b, byte((hi * 16) + lo))
                        i = i + 3
                        continue
                    }
                }
            }
        }
        if c == 43 {
            builder_write(b, " ")
        } else {
            builder_write_byte(b, data[i])
        }
        i = i + 1
    }
    return builder_string(b)
}

fn query_value(path: string, key: string) -> string {
    let q = query_of(path)
    if str_len(q) == 0 {
        return ""
    }
    let raw = substr(q, 1, str_len(q))
    let parts = str_split(raw, "&")
    for i, part in range parts {
        let cut = str_cut(part, "=")
        if len(cut) >= 2 {
            if str_eq(url_decode(cut[0]), key) {
                return own_string(url_decode(cut[1]))
            }
        }
    }
    return ""
}

fn is_ident_char(c: int) -> int {
    if c >= 48 {
        if c <= 57 {
            return 1
        }
    }
    if c >= 65 {
        if c <= 90 {
            return 1
        }
    }
    if c >= 97 {
        if c <= 122 {
            return 1
        }
    }
    if c == 45 {
        return 1
    }
    if c == 46 {
        return 1
    }
    if c == 95 {
        return 1
    }
    return 0
}

fn valid_admin_name(s: string) -> int {
    if str_eq(s, "") {
        return 0
    }
    if str_len(s) > 96 {
        return 0
    }
    let data = bytes(s)
    for i, d in range data {
        if is_ident_char(int(d)) == 0 {
            return 0
        }
    }
    return 1
}

fn valid_domain(s: string) -> int {
    if valid_admin_name(s) == 0 {
        return 0
    }
    if str_contains(s, "..") {
        return 0
    }
    if str_has_prefix(s, ".") {
        return 0
    }
    if str_has_suffix(s, ".") {
        return 0
    }
    return 1
}

// SNI hostname: exact domain, or left-most wildcard (*.example.com). Mako rejects nested wildcards.
fn valid_sni_hostname(s: string) -> int {
    if str_eq(s, "") {
        return 0
    }
    if str_has_prefix(s, "*.") {
        // Strip "*." and validate the rest as a domain (no further wildcards).
        let rest = substr(s, 2, str_len(s))
        if str_contains(rest, "*") {
            return 0
        }
        return valid_domain(rest)
    }
    if str_contains(s, "*") {
        return 0
    }
    return valid_domain(s)
}

fn valid_abs_path(s: string) -> int {
    if str_eq(s, "") {
        return 1
    }
    if not path_is_abs(s) {
        return 0
    }
    if str_contains(s, "\n") {
        return 0
    }
    if str_contains(s, "\r") {
        return 0
    }
    // Path traversal / relative segments in absolute paths.
    if str_contains(s, "/../") {
        return 0
    }
    if str_has_suffix(s, "/..") {
        return 0
    }
    if str_contains(s, "/./") {
        return 0
    }
    return 1
}

fn find_backend_idx_admin(backends: []Backend, name: string) -> int {
    for i, be in range backends {
        if str_eq(be.name, name) {
            return i
        }
    }
    return -1
}

fn find_frontend_idx_admin(frontends: []Frontend, name: string) -> int {
    for i, fe in range frontends {
        if str_eq(fe.name, name) {
            return i
        }
    }
    return -1
}

fn upsert_host_route(routes: []Route, frontend: string, domain: string, backend: string) -> []Route {
    return upsert_host_route_full(routes, frontend, domain, backend, "", "", 0, 1, 1)
}

// action: "" | redirect | dead; enable 0/1; websocket 0/1
fn upsert_host_route_full(
    routes: []Route,
    frontend: string,
    domain: string,
    backend: string,
    action: string,
    target: string,
    code: int,
    websocket: int,
    enable: int
) -> []Route {
    let mut out = routes
    for i, rt in range out {
        if str_eq(rt.frontend, frontend) {
            if str_eq(rt.kind, "host") {
                if str_eq(rt.value, domain) {
                    let mut r = out[i]
                    if not str_eq(backend, "") {
                        r.backend = backend
                    }
                    if enable == 0 {
                        r.action = "dead"
                        if code > 0 {
                            r.code = code
                        } else {
                            r.code = 503
                        }
                    } else {
                        if str_eq(action, "redirect") {
                            r.action = "redirect"
                            r.target = target
                            r.backend = ""
                            if code > 0 {
                                r.code = code
                            } else {
                                r.code = 301
                            }
                        } else {
                            if str_eq(action, "dead") {
                                r.action = "dead"
                                r.backend = ""
                                if code > 0 {
                                    r.code = code
                                } else {
                                    r.code = 404
                                }
                            } else {
                                r.action = ""
                                r.target = ""
                            }
                        }
                    }
                    r.websocket = websocket
                    out[i] = r
                    return out
                }
            }
        }
    }
    let mut nr = route_new(frontend, "host", domain, backend)
    if enable == 0 {
        nr = route_dead_new(frontend, "host", domain, 503)
    } else {
        if str_eq(action, "redirect") {
            nr = route_redirect_new(frontend, "host", domain, target, code)
        } else {
            if str_eq(action, "dead") {
                nr = route_dead_new(frontend, "host", domain, code)
            }
        }
    }
    nr.websocket = websocket
    return append(out, route_clone(nr))
}

fn remove_host_locations(routes: []Route, frontend: string, domain: string) -> []Route {
    let mut out = make([]Route, 0, len(routes))
    for _, rt in range routes {
        if str_eq(rt.frontend, frontend) {
            if str_eq(rt.host_match, domain) {
                continue
            }
        }
        out = append(out, route_clone(rt))
    }
    return out
}

fn upsert_location_route(routes: []Route, frontend: string, domain: string, path_prefix: string, backend: string, websocket: int) -> []Route {
    let mut out = routes
    for i, rt in range out {
        if str_eq(rt.frontend, frontend) {
            if str_eq(rt.host_match, domain) {
                if str_eq(rt.value, path_prefix) {
                    let mut r = out[i]
                    r.backend = backend
                    r.kind = "path_prefix"
                    r.websocket = websocket
                    r.action = ""
                    out[i] = r
                    return out
                }
            }
        }
    }
    let mut nr = route_location_new(frontend, domain, path_prefix, backend)
    nr.websocket = websocket
    return append(out, route_clone(nr))
}

fn remove_location_route(routes: []Route, frontend: string, domain: string, path_prefix: string) -> []Route {
    let mut out = make([]Route, 0, len(routes))
    for _, rt in range routes {
        if str_eq(rt.frontend, frontend) {
            if str_eq(rt.host_match, domain) {
                if str_eq(rt.value, path_prefix) {
                    continue
                }
            }
        }
        out = append(out, route_clone(rt))
    }
    return out
}

fn ensure_backend(backends: []Backend, name: string) -> []Backend {
    if find_backend_idx_admin(backends, name) >= 0 {
        return backends
    }
    return append(backends, backend_new(name))
}

fn upsert_backend_server(servers: []Server, backend: string, name: string, addr: string) -> []Server {
    let hp = parse_host_port(addr)
    let port = to_int(hp.port)
    let idx = find_server_idx(servers, backend, name)
    if idx >= 0 {
        let mut out = server_array_clone(servers)
        let mut s = server_clone(out[idx])
        s.host = own_string(hp.host)
        s.port = port
        s.alive = 1
        s.drain = 0
        out[idx] = s
        return out
    }
    return append(servers, server_new(name, hp.host, port, 1, 1, backend))
}

fn admin_vhost_backends(need_upstream: int, backends: []Backend, name: string) -> []Backend {
    let mut out = backend_array_clone(backends)
    if need_upstream == 1 {
        if find_backend_idx_admin(out, name) < 0 {
            out = append(out, backend_new(name))
        }
    }
    return out
}

fn admin_vhost_servers(need_upstream: int, servers: []Server, backend: string, name: string, addr: string) -> []Server {
    if need_upstream == 1 {
        return upsert_backend_server(server_array_clone(servers), backend, name, addr)
    }
    return server_array_clone(servers)
}

fn admin_vhosts_json(frontends: []Frontend, backends: []Backend, servers: []Server, routes: []Route) -> string {
    let mut b = str_builder()
    builder_write(b, "{\"vhosts\":[")
    let mut first = 1
    for i, r in range routes {
        if str_eq(r.kind, "host") {
            if first == 0 {
                builder_write(b, ",")
            }
            first = 0
            let mut enabled = 1
            if str_eq(r.action, "dead") {
                enabled = 0
            }
            builder_write(b, "{\"frontend\":\"")
            builder_write(b, json_escape(r.frontend))
            builder_write(b, "\",\"domain\":\"")
            builder_write(b, json_escape(r.value))
            builder_write(b, "\",\"backend\":\"")
            builder_write(b, json_escape(r.backend))
            builder_write(b, "\",\"action\":\"")
            builder_write(b, json_escape(r.action))
            builder_write(b, "\",\"target\":\"")
            builder_write(b, json_escape(r.target))
            builder_write(b, "\",\"code\":")
            builder_write(b, int_to_string(r.code))
            builder_write(b, ",\"enabled\":")
            builder_write(b, int_to_string(enabled))
            builder_write(b, ",\"websocket\":")
            builder_write(b, int_to_string(r.websocket))
            builder_write(b, ",\"locations\":[")
            let mut lf = 1
            for _, loc in range routes {
                if str_eq(loc.frontend, r.frontend) {
                    if not str_eq(loc.kind, "host") {
                        if str_eq(loc.host_match, r.value) {
                            if lf == 0 {
                                builder_write(b, ",")
                            }
                            lf = 0
                            builder_write(b, "{\"path\":\"")
                            builder_write(b, json_escape(loc.value))
                            builder_write(b, "\",\"kind\":\"")
                            builder_write(b, json_escape(loc.kind))
                            builder_write(b, "\",\"backend\":\"")
                            builder_write(b, json_escape(loc.backend))
                            builder_write(b, "\",\"websocket\":")
                            builder_write(b, int_to_string(loc.websocket))
                            builder_write(b, "}")
                        }
                    }
                }
            }
            builder_write(b, "],\"servers\":[")
            let mut sf = 1
            for si, s in range servers {
                if str_eq(s.backend, r.backend) {
                    if sf == 0 {
                        builder_write(b, ",")
                    }
                    sf = 0
                    builder_write(b, "{\"name\":\"")
                    builder_write(b, json_escape(s.name))
                    builder_write(b, "\",\"addr\":\"")
                    builder_write(b, json_escape(join_host_port(s.host, s.port)))
                    builder_write(b, "\",\"alive\":")
                    builder_write(b, int_to_string(s.alive))
                    builder_write(b, ",\"drain\":")
                    builder_write(b, int_to_string(s.drain))
                    builder_write(b, "}")
                }
            }
            builder_write(b, "]}")
        }
    }
    builder_write(b, "],\"frontends\":[")
    for fi, fe in range frontends {
        if fi > 0 {
            builder_write(b, ",")
        }
        builder_write(b, "{\"name\":\"")
        builder_write(b, json_escape(fe.name))
        builder_write(b, "\",\"mode\":\"")
        builder_write(b, json_escape(fe.mode))
        builder_write(b, "\",\"port\":")
        builder_write(b, int_to_string(fe.bind_port))
        builder_write(b, ",\"tls_cert\":\"")
        builder_write(b, json_escape(fe.tls_cert))
        builder_write(b, "\",\"tls_key\":\"")
        builder_write(b, json_escape(fe.tls_key))
        builder_write(b, "\",\"tls_sni\":[")
        for si, se in range fe.tls_sni {
            if si > 0 {
                builder_write(b, ",")
            }
            builder_write(b, "{\"hostname\":\"")
            builder_write(b, json_escape(se.hostname))
            builder_write(b, "\",\"cert\":\"")
            builder_write(b, json_escape(se.cert))
            builder_write(b, "\",\"key\":\"")
            builder_write(b, json_escape(se.key))
            builder_write(b, "\"}")
        }
        builder_write(b, "]}")
    }
    builder_write(b, "],\"managed_file\":\"leba.vhosts.conf\"}\n")
    return builder_string(b)
}

fn render_route_line(rt: Route) -> string {
    let mut b = str_builder()
    builder_write(b, "  route ")
    builder_write(b, rt.kind)
    if not str_eq(rt.kind, "default") {
        builder_write(b, " ")
        builder_write(b, rt.value)
    }
    if str_eq(rt.action, "redirect") {
        builder_write(b, " redirect ")
        builder_write(b, rt.target)
        if rt.code > 0 {
            builder_write(b, " ")
            builder_write(b, int_to_string(rt.code))
        }
        builder_write(b, "\n")
        return builder_string(b)
    }
    if str_eq(rt.action, "dead") {
        builder_write(b, " dead")
        if rt.code > 0 {
            builder_write(b, " ")
            builder_write(b, int_to_string(rt.code))
        }
        builder_write(b, "\n")
        return builder_string(b)
    }
    // path location under host: path_prefix /api host example.com -> be
    if not str_eq(rt.host_match, "") {
        if not str_eq(rt.kind, "host") {
            builder_write(b, " host ")
            builder_write(b, rt.host_match)
        }
    }
    builder_write(b, " -> ")
    builder_write(b, rt.backend)
    if rt.websocket == 0 {
        builder_write(b, " websocket off")
    }
    builder_write(b, "\n")
    return builder_string(b)
}

fn render_managed_frontend_header(fe: Frontend) -> string {
    let mut b = str_builder()
    builder_write(b, f"\nfrontend {fe.name}\n")
    if not str_eq(fe.tls_cert, "") {
        builder_write(b, f"  tls_cert {fe.tls_cert}\n")
    }
    if not str_eq(fe.tls_key, "") {
        builder_write(b, f"  tls_key {fe.tls_key}\n")
    }
    for _, se in range fe.tls_sni {
        builder_write(b, f"  tls_sni {se.hostname} {se.cert} {se.key}\n")
    }
    if fe.redirect_https == 1 {
        if fe.redirect_code > 0 {
            builder_write(b, f"  redirect https {fe.redirect_code}\n")
        } else {
            builder_write(b, "  redirect https\n")
        }
    }
    if not str_eq(fe.waf_mode, "") {
        if not str_eq(fe.waf_mode, "off") {
            builder_write(b, f"  waf {fe.waf_mode}\n")
            if not str_eq(fe.waf_url, "") {
                builder_write(b, f"  waf_url {fe.waf_url}\n")
            }
            if not str_eq(fe.waf_fail, "") {
                if not str_eq(fe.waf_fail, "open") {
                    builder_write(b, f"  waf_fail {fe.waf_fail}\n")
                }
            }
        }
    }
    return builder_string(b)
}

fn render_managed_vhosts(frontends: []Frontend, backends: []Backend, servers: []Server, routes: []Route) -> string {
    let mut b = str_builder()
    builder_write(b, "# Generated by Leba admin (0.13 ops). Include from leba.conf.\n")
    for fi, fe in range frontends {
        let mut wrote = 0
        // Locations first (path_prefix with host_match), then host routes.
        for ri, rt in range routes {
            if str_eq(rt.frontend, fe.name) {
                let mut is_loc = 0
                if not str_eq(rt.kind, "host") {
                    if not str_eq(rt.kind, "default") {
                        if not str_eq(rt.host_match, "") {
                            is_loc = 1
                        }
                    }
                }
                if is_loc == 1 {
                    if wrote == 0 {
                        builder_write(b, render_managed_frontend_header(fe))
                        wrote = 1
                    }
                    builder_write(b, render_route_line(rt))
                }
            }
        }
        for ri, rt in range routes {
            if str_eq(rt.frontend, fe.name) {
                if str_eq(rt.kind, "host") {
                    if wrote == 0 {
                        builder_write(b, render_managed_frontend_header(fe))
                        wrote = 1
                    }
                    builder_write(b, render_route_line(rt))
                }
            }
        }
    }
    for bi, be in range backends {
        let mut used = 0
        for ri2, rt in range routes {
            if str_eq(rt.backend, be.name) {
                used = 1
            }
        }
        if used == 1 {
            builder_write(b, f"\nbackend {be.name}\n  balance {be.balance}\n")
            for si, s in range servers {
                if str_eq(s.backend, be.name) {
                    let mut chk = "off"
                    if s.check == 1 {
                        chk = "on"
                    }
                    builder_write(b, f"  server {s.name} {join_host_port(s.host, s.port)} weight {s.weight} check {chk}")
                    if s.maxconn > 0 {
                        builder_write(b, f" maxconn {s.maxconn}")
                    }
                    builder_write(b, "\n")
                }
            }
        }
    }
    return builder_string(b)
}

fn ensure_managed_include_named(config_path: string, name: string, comment: string) -> int {
    if str_eq(config_path, "") {
        return 1
    }
    let raw = read_file(config_path)
    if str_eq(raw, "") {
        return 0
    }
    let needle = "include " + name
    if str_contains(raw, needle) {
        return 1
    }
    let mut b = str_builder()
    builder_write(b, raw)
    if not str_has_suffix(raw, "\n") {
        builder_write(b, "\n")
    }
    builder_write(b, "\n# ")
    builder_write(b, comment)
    builder_write(b, "\ninclude ")
    builder_write(b, name)
    builder_write(b, "\n")
    if write_file(config_path, builder_string(b)) == 0 {
        return 1
    }
    return 0
}

fn ensure_managed_include(config_path: string) -> int {
    return ensure_managed_include_named(config_path, "leba.vhosts.conf", "Admin-managed virtual hosts.")
}

fn save_managed_vhosts(config_path: string, config_dir: string, frontends: []Frontend, backends: []Backend, servers: []Server, routes: []Route) -> int {
    let full = resolve_servers_path(config_dir, "leba.vhosts.conf")
    let ok = write_file(full, render_managed_vhosts(frontends, backends, servers, routes))
    if ok != 0 {
        return 0
    }
    return ensure_managed_include(config_path)
}

// --- Access lists + app HTTP Basic (managed include) -----------------------

fn render_managed_access(frontends: []Frontend, acls: []AclRule, auth_blob: string) -> string {
    let mut b = str_builder()
    builder_write(b, "# Generated by Leba admin — access lists and app HTTP Basic.\n")
    for _, fe in range frontends {
        let mut need = 0
        if not str_eq(fe.auth_basic_realm, "") {
            need = 1
        }
        for _, a in range acls {
            if str_eq(a.frontend, fe.name) {
                need = 1
            }
        }
        // auth_blob may contain lines for this frontend already; still open section if realm set or acls
        if need == 0 {
            continue
        }
        builder_write(b, f"\nfrontend {fe.name}\n")
        if not str_eq(fe.auth_basic_realm, "") {
            // Realm may contain spaces — quote when needed.
            if str_contains(fe.auth_basic_realm, " ") {
                builder_write(b, "  auth_basic \"")
                builder_write(b, fe.auth_basic_realm)
                builder_write(b, "\"\n")
            } else {
                builder_write(b, f"  auth_basic {fe.auth_basic_realm}\n")
            }
        }
        for _, a in range acls {
            if str_eq(a.frontend, fe.name) {
                builder_write(b, f"  {a.action} {a.kind} {a.value}\n")
            }
        }
    }
    if not str_eq(auth_blob, "") {
        builder_write(b, "\n# auth_user lines (passwords — protect this file)\n")
        builder_write(b, auth_blob)
        if not str_has_suffix(auth_blob, "\n") {
            builder_write(b, "\n")
        }
    }
    return builder_string(b)
}

fn read_managed_auth_blob(config_dir: string) -> string {
    let full = resolve_servers_path(config_dir, "leba.access.conf")
    let raw = read_file(full)
    if str_eq(raw, "") {
        return ""
    }
    let mut b = str_builder()
    let lines = str_split(raw, "\n")
    let mut cur_fe = ""
    for _, line in range lines {
        let t = str_trim_space(line)
        if str_eq(t, "") {
            continue
        }
        if str_has_prefix(t, "#") {
            continue
        }
        let fields = str_fields(t)
        if len(fields) == 0 {
            continue
        }
        if str_eq(fields[0], "frontend") {
            if len(fields) >= 2 {
                cur_fe = fields[1]
            }
            continue
        }
        if str_eq(fields[0], "auth_user") {
            if len(fields) >= 3 {
                if not str_eq(cur_fe, "") {
                    builder_write(b, "frontend ")
                    builder_write(b, cur_fe)
                    builder_write(b, "\n  auth_user ")
                    builder_write(b, fields[1])
                    builder_write(b, " ")
                    builder_write(b, fields[2])
                    if len(fields) >= 5 {
                        if str_eq(fields[3], "host") {
                            builder_write(b, " host ")
                            builder_write(b, fields[4])
                        }
                    }
                    builder_write(b, "\n")
                }
            }
        }
    }
    return builder_string(b)
}

fn upsert_auth_user_blob_host(blob: string, frontend: string, host: string, user: string, pass: string) -> string {
    // Store host-scoped lines as: FE|HOST|USER|PASS
    let lines = str_split(blob, "\n")
    let mut keep = make([]string, 0, 8)
    let mut cur = ""
    for _, line in range lines {
        let t = str_trim_space(line)
        if str_eq(t, "") {
            continue
        }
        let fields = str_fields(t)
        if len(fields) == 0 {
            continue
        }
        if str_eq(fields[0], "frontend") {
            if len(fields) >= 2 {
                cur = fields[1]
            }
            continue
        }
        if str_eq(fields[0], "auth_user") {
            if len(fields) >= 3 {
                let mut h = ""
                if len(fields) >= 5 {
                    if str_eq(fields[3], "host") {
                        h = fields[4]
                    }
                }
                if str_eq(cur, frontend) {
                    if str_eq(fields[1], user) {
                        if str_eq(h, host) {
                            continue
                        }
                    }
                }
                keep = append(keep, cur + " " + fields[1] + " " + fields[2] + " " + h)
            }
        }
    }
    keep = append(keep, frontend + " " + user + " " + pass + " " + host)
    let mut out = str_builder()
    let mut last_fe = ""
    for _, row in range keep {
        let parts = str_fields(row)
        if len(parts) < 3 {
            continue
        }
        if not str_eq(parts[0], last_fe) {
            builder_write(out, "frontend ")
            builder_write(out, parts[0])
            builder_write(out, "\n")
            last_fe = parts[0]
        }
        builder_write(out, "  auth_user ")
        builder_write(out, parts[1])
        builder_write(out, " ")
        builder_write(out, parts[2])
        if len(parts) >= 4 {
            if not str_eq(parts[3], "") {
                builder_write(out, " host ")
                builder_write(out, parts[3])
            }
        }
        builder_write(out, "\n")
    }
    return builder_string(out)
}

fn upsert_auth_user_blob(blob: string, frontend: string, user: string, pass: string) -> string {
    // Re-render as frontend sections with auth_user lines only.
    let mut keep = make([]string, 0, 8)
    let lines = str_split(blob, "\n")
    let mut cur = ""
    for _, line in range lines {
        let t = str_trim_space(line)
        if str_eq(t, "") {
            continue
        }
        let fields = str_fields(t)
        if len(fields) == 0 {
            continue
        }
        if str_eq(fields[0], "frontend") {
            if len(fields) >= 2 {
                cur = fields[1]
            }
            continue
        }
        if str_eq(fields[0], "auth_user") {
            if len(fields) >= 3 {
                if str_eq(cur, frontend) {
                    if str_eq(fields[1], user) {
                        continue
                    }
                }
                keep = append(keep, cur + " " + fields[1] + " " + fields[2])
            }
        }
    }
    keep = append(keep, frontend + " " + user + " " + pass)
    let mut out = str_builder()
    let mut last_fe = ""
    for _, row in range keep {
        let parts = str_fields(row)
        if len(parts) < 3 {
            continue
        }
        if not str_eq(parts[0], last_fe) {
            builder_write(out, "frontend ")
            builder_write(out, parts[0])
            builder_write(out, "\n")
            last_fe = parts[0]
        }
        builder_write(out, "  auth_user ")
        builder_write(out, parts[1])
        builder_write(out, " ")
        builder_write(out, parts[2])
        builder_write(out, "\n")
    }
    return builder_string(out)
}

fn delete_auth_user_blob(blob: string, frontend: string, user: string) -> string {
    let lines = str_split(blob, "\n")
    let mut keep = make([]string, 0, 8)
    let mut cur = ""
    for _, line in range lines {
        let t = str_trim_space(line)
        if str_eq(t, "") {
            continue
        }
        let fields = str_fields(t)
        if len(fields) == 0 {
            continue
        }
        if str_eq(fields[0], "frontend") {
            if len(fields) >= 2 {
                cur = fields[1]
            }
            continue
        }
        if str_eq(fields[0], "auth_user") {
            if len(fields) >= 3 {
                if str_eq(cur, frontend) {
                    if str_eq(fields[1], user) {
                        continue
                    }
                }
                keep = append(keep, cur + " " + fields[1] + " " + fields[2])
            }
        }
    }
    let mut out = str_builder()
    let mut last_fe = ""
    for _, row in range keep {
        let parts = str_fields(row)
        if len(parts) < 3 {
            continue
        }
        if not str_eq(parts[0], last_fe) {
            builder_write(out, "frontend ")
            builder_write(out, parts[0])
            builder_write(out, "\n")
            last_fe = parts[0]
        }
        builder_write(out, "  auth_user ")
        builder_write(out, parts[1])
        builder_write(out, " ")
        builder_write(out, parts[2])
        builder_write(out, "\n")
    }
    return builder_string(out)
}

fn save_managed_access(config_path: string, config_dir: string, frontends: []Frontend, acls: []AclRule, auth_blob: string) -> int {
    let full = resolve_servers_path(config_dir, "leba.access.conf")
    let ok = write_file(full, render_managed_access(frontends, acls, auth_blob))
    if ok != 0 {
        return 0
    }
    return ensure_managed_include_named(config_path, "leba.access.conf", "Admin-managed access lists and app HTTP Basic.")
}

fn acls_json(acls: []AclRule) -> string {
    let mut b = str_builder()
    builder_write(b, "{\"access_lists\":[")
    for i, a in range acls {
        if i > 0 {
            builder_write(b, ",")
        }
        builder_write(b, "{\"frontend\":\"")
        builder_write(b, json_escape(a.frontend))
        builder_write(b, "\",\"action\":\"")
        builder_write(b, json_escape(a.action))
        builder_write(b, "\",\"kind\":\"")
        builder_write(b, json_escape(a.kind))
        builder_write(b, "\",\"value\":\"")
        builder_write(b, json_escape(a.value))
        builder_write(b, "\"}")
    }
    builder_write(b, "],\"managed_file\":\"leba.access.conf\"}\n")
    return builder_string(b)
}

fn http_auth_json(frontends: []Frontend, auth_blob: string) -> string {
    let mut b = str_builder()
    builder_write(b, "{\"http_auth\":[")
    let mut first = 1
    for _, fe in range frontends {
        if not str_eq(fe.auth_basic_realm, "") {
            if first == 0 {
                builder_write(b, ",")
            }
            first = 0
            builder_write(b, "{\"frontend\":\"")
            builder_write(b, json_escape(fe.name))
            builder_write(b, "\",\"realm\":\"")
            builder_write(b, json_escape(fe.auth_basic_realm))
            builder_write(b, "\",\"users\":[")
            let mut uf = 1
            let lines = str_split(auth_blob, "\n")
            let mut cur = ""
            for _, line in range lines {
                let t = str_trim_space(line)
                let fields = str_fields(t)
                if len(fields) == 0 {
                    continue
                }
                if str_eq(fields[0], "frontend") {
                    if len(fields) >= 2 {
                        cur = fields[1]
                    }
                    continue
                }
                if str_eq(fields[0], "auth_user") {
                    if str_eq(cur, fe.name) {
                        if len(fields) >= 2 {
                            if uf == 0 {
                                builder_write(b, ",")
                            }
                            uf = 0
                            builder_write(b, "\"")
                            builder_write(b, json_escape(fields[1]))
                            builder_write(b, "\"")
                        }
                    }
                }
            }
            builder_write(b, "]}")
        }
    }
    builder_write(b, "],\"managed_file\":\"leba.access.conf\",\"note\":\"passwords never returned\"}\n")
    return builder_string(b)
}

fn acl_upsert(acls: []AclRule, frontend: string, action: string, kind: string, value: string) -> []AclRule {
    for _, a in range acls {
        if str_eq(a.frontend, frontend) {
            if str_eq(a.action, action) {
                if str_eq(a.kind, kind) {
                    if str_eq(a.value, value) {
                        return acls
                    }
                }
            }
        }
    }
    return append(acls, acl_new(frontend, action, kind, value))
}

fn acl_remove(acls: []AclRule, frontend: string, action: string, kind: string, value: string) -> []AclRule {
    let mut out = make([]AclRule, 0, len(acls))
    for _, a in range acls {
        if str_eq(a.frontend, frontend) {
            if str_eq(a.action, action) {
                if str_eq(a.kind, kind) {
                    if str_eq(a.value, value) {
                        continue
                    }
                }
            }
        }
        out = append(out, a)
    }
    return out
}

fn valid_acl_action(s: string) -> int {
    if str_eq(s, "allow") {
        return 1
    }
    if str_eq(s, "deny") {
        return 1
    }
    return 0
}

fn valid_acl_kind(s: string) -> int {
    if str_eq(s, "src") {
        return 1
    }
    if str_eq(s, "path") {
        return 1
    }
    if str_eq(s, "path_prefix") {
        return 1
    }
    if str_eq(s, "host") {
        return 1
    }
    if str_eq(s, "method") {
        return 1
    }
    if str_eq(s, "header") {
        return 1
    }
    return 0
}

fn find_server_idx(servers: []Server, backend: string, name: string) -> int {
    for i, srv in range servers {
        if str_eq(srv.backend, backend) {
            if str_eq(srv.name, name) {
                return i
            }
        }
    }
    return -1
}

fn servers_json(servers: []Server) -> string {
    let mut b = str_builder()
    builder_write(b, "{\"servers\":[")
    for i, s in range servers {
        if i > 0 {
            builder_write(b, ",")
        }
        builder_write(b, "{\"backend\":\"")
        builder_write(b, json_escape(s.backend))
        builder_write(b, "\",\"name\":\"")
        builder_write(b, json_escape(s.name))
        builder_write(b, "\",\"addr\":\"")
        builder_write(b, json_escape(join_host_port(s.host, s.port)))
        builder_write(b, "\",\"alive\":")
        builder_write(b, int_to_string(s.alive))
        builder_write(b, ",\"drain\":")
        builder_write(b, int_to_string(s.drain))
        builder_write(b, ",\"conns\":")
        builder_write(b, int_to_string(s.conns))
        builder_write(b, ",\"weight\":")
        builder_write(b, int_to_string(s.weight))
        builder_write(b, ",\"total_req\":")
        builder_write(b, int_to_string(s.total_req))
        builder_write(b, "}")
    }
    builder_write(b, "]}\n")
    return builder_string(b)
}

fn admin_help_json() -> string {
    return "{\"endpoints\":[\"/admin/servers\",\"/admin/reload-servers\",\"/admin/tls-reload\",\"/admin/vhosts\",\"/admin/vhost-create\",\"/admin/proxy-hosts\",\"/admin/proxy-host\",\"/admin/proxy-host-delete\",\"/admin/certificates\",\"/admin/certificates/issue\",\"/admin/certificates/renew\",\"/admin/access-lists\",\"/admin/access-list\",\"/admin/access-list-delete\",\"/admin/http-auth\",\"/admin/http-auth-delete\",\"/admin/http-auth-realm\",\"/admin/stick-tables\",\"/admin/stick-tables/entries\",\"/admin/doctor\",\"/admin/explain\",\"/admin/preview-reload\",\"/admin/server\",\"/admin/server-delete\",\"/admin/waf-mode\",\"/admin/waf-rules\",\"/admin/drain/{backend}/{server}\",\"/admin/ready/{backend}/{server}\",\"/admin/disable/{backend}/{server}\",\"/admin/enable/{backend}/{server}\",\"/readyz\",\"/livez\",\"/health\",\"/stats\",\"/metrics\"],\"note\":\"Use POST for mutating admin routes; DELETE for stick-tables\"}\n"
}

fn remove_host_route(routes: []Route, frontend: string, domain: string) -> []Route {
    let mut out = make([]Route, 0, len(routes))
    for _, rt in range routes {
        if str_eq(rt.frontend, frontend) {
            if str_eq(rt.kind, "host") {
                if str_eq(rt.value, domain) {
                    continue
                }
            }
            // Drop locations under this host.
            if str_eq(rt.host_match, domain) {
                continue
            }
        }
        out = append(out, route_clone(rt))
    }
    return out
}

fn any_ready(servers: []Server) -> int {
    for i, srv in range servers {
        if srv.alive == 1 {
            if srv.drain == 0 {
                return 1
            }
        }
    }
    return 0
}

fn set_server_drain(servers: []Server, idx: int, drain: int) -> []Server {
    if idx < 0 {
        return servers
    }
    let mut out = server_array_clone(servers)
    let mut s = server_clone(out[idx])
    s.drain = drain
    out[idx] = s
    return out
}

fn set_server_alive(servers: []Server, idx: int, alive: int) -> []Server {
    if idx < 0 {
        return servers
    }
    let mut out = server_array_clone(servers)
    let mut s = server_clone(out[idx])
    s.alive = alive
    if alive == 1 {
        s.fails = 0
    }
    out[idx] = s
    return out
}

// Returns handled=1 if path was an admin/ops path
fn handle_admin(
    method: string,
    path: string,
    servers: []Server,
    backends: []Backend,
    config_dir: string
) -> AdminResult {
    // /livez
    if str_eq(path, "/livez") {
        return AdminResult {
            handled: 1,
            status: 200,
            body: "{\"live\":true}\n",
            servers: server_array_clone(servers)
        }
    }
    // /readyz
    if str_eq(path, "/readyz") {
        if any_ready(servers) == 1 {
            return AdminResult {
                handled: 1,
                status: 200,
                body: "{\"ready\":true}\n",
                servers: server_array_clone(servers)
            }
        }
        return AdminResult {
            handled: 1,
            status: 503,
            body: "{\"ready\":false}\n",
            servers: server_array_clone(servers)
        }
    }

    if str_eq(path, "/admin") {
        return AdminResult {
            handled: 1,
            status: 200,
            body: admin_help_json(),
            servers: server_array_clone(servers)
        }
    }
    if str_eq(path, "/admin/") {
        return AdminResult {
            handled: 1,
            status: 200,
            body: admin_help_json(),
            servers: server_array_clone(servers)
        }
    }
    if str_eq(path, "/admin/servers") {
        return AdminResult {
            handled: 1,
            status: 200,
            body: servers_json(servers),
            servers: server_array_clone(servers)
        }
    }
    if str_eq(path, "/admin/reload-servers") {
        if not str_eq(method, "POST") {
            log_warn_event("admin_method_not_allowed", "action=reload-servers status=405")
            return AdminResult {
                handled: 1,
                status: 405,
                body: "{\"error\":\"method not allowed\"}\n",
                servers: server_array_clone(servers)
            }
        }
        let rr = reload_servers_files(backends, servers, config_dir)
        if rr.ok == 0 {
            log_warn_event("admin_reload_servers_failed", f"action=reload-servers status=400 error=\"{json_escape(rr.error)}\"")
            return AdminResult {
                handled: 1,
                status: 400,
                body: f"{{\"error\":\"{json_escape(rr.error)}\"}}\n",
                servers: server_array_clone(servers)
            }
        }
        log_info_event("admin_action", f"action=reload-servers status=200 loaded={rr.loaded} servers={len(rr.servers)}")
        return AdminResult {
            handled: 1,
            status: 200,
            body: f"{{\"ok\":true,\"action\":\"reload-servers\",\"loaded\":{rr.loaded},\"servers\":{len(rr.servers)}}}\n",
            servers: rr.servers
        }
    }

    // /admin/{action}/{backend}/{server}
    let p1 = path_part(path, 1)
    let p2 = path_part(path, 2)
    let p3 = path_part(path, 3)
    let p4 = path_part(path, 4)
    if not str_eq(p1, "admin") {
        return AdminResult {
            handled: 0,
            status: 0,
            body: "",
            servers: server_array_clone(servers)
        }
    }
    if str_eq(p2, "") {
        return AdminResult {
            handled: 1,
            status: 200,
            body: admin_help_json(),
            servers: server_array_clone(servers)
        }
    }

    if not str_eq(method, "POST") {
        log_warn_event("admin_method_not_allowed", f"action={p2} status=405")
        return AdminResult {
            handled: 1,
            status: 405,
            body: "{\"error\":\"method not allowed\"}\n",
            servers: server_array_clone(servers)
        }
    }

    // actions that need backend+server
    if str_eq(p3, "") {
        log_warn_event("admin_bad_request", "reason=missing_backend_or_server status=400")
        return AdminResult {
            handled: 1,
            status: 400,
            body: "{\"error\":\"need /admin/{action}/{backend}/{server}\"}\n",
            servers: server_array_clone(servers)
        }
    }
    if str_eq(p4, "") {
        log_warn_event("admin_bad_request", "reason=missing_backend_or_server status=400")
        return AdminResult {
            handled: 1,
            status: 400,
            body: "{\"error\":\"need /admin/{action}/{backend}/{server}\"}\n",
            servers: server_array_clone(servers)
        }
    }

    let idx = find_server_idx(servers, p3, p4)
    if idx < 0 {
        log_warn_event("admin_server_not_found", f"backend={p3} server={p4} status=404")
        return AdminResult {
            handled: 1,
            status: 404,
            body: "{\"error\":\"server not found\"}\n",
            servers: server_array_clone(servers)
        }
    }

    // Mutate the shared server table in place. Do not reassign the []Server
    // local from a call result inside match arms — Mako SAFE free of the
    // reassigned value at arm scope exit frees the live table (use-after-free).
    let mut out = server_array_clone(servers)
    let mut s = server_clone(out[idx])
    match p2 {
        "drain" => {
            s.drain = 1
        }
        "ready" => {
            s.drain = 0
            s.alive = 1
            s.fails = 0
        }
        "disable" => {
            s.alive = 0
        }
        "enable" => {
            s.alive = 1
            s.fails = 0
            s.drain = 0
        }
        _ => {
            log_warn_event("admin_unknown_action", f"action={p2} backend={p3} server={p4} status=404")
            return AdminResult {
                handled: 1,
                status: 404,
                body: "{\"error\":\"unknown action\"}\n",
                servers: server_array_clone(servers)
            }
        }
    }
    out[idx] = s

    log_info_event("admin_action", f"action={p2} backend={p3} server={p4} status=200")

    return AdminResult {
        handled: 1,
        status: 200,
        body: f"{{\"ok\":true,\"action\":\"{p2}\",\"backend\":\"{json_escape(p3)}\",\"server\":\"{json_escape(p4)}\"}}\n",
        servers: out
    }
}

fn handle_admin_state(
    method: string,
    path: string,
    full_path: string,
    servers: []Server,
    frontends_in: []Frontend,
    backends_in: []Backend,
    routes_in: []Route,
    acls_in: []AclRule,
    config_path: string,
    config_dir: string
) -> AdminStateResult {
    let mut frontends = frontend_array_clone(frontends_in)
    let mut backends = backend_array_clone(backends_in)
    let mut routes = route_array_clone(routes_in)
    let mut acls = acl_array_clone(acls_in)

    // Doctor report on current config file (viewer+).
    if str_eq(path, "/admin/doctor") {
        if not str_eq(method, "GET") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let w = parse_config_file(config_path)
        if w.ok == 0 {
            let mut eb = str_builder()
            builder_write(eb, "{\"ok\":false,\"error\":\"")
            builder_write(eb, json_escape(w.error))
            builder_write(eb, "\"}\n")
            return AdminStateResult { handled: 1, status: 400, body: builder_string(eb), servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let rep = doctor_world(w)
        let mut b = str_builder()
        builder_write(b, "{\"ok\":")
        if rep.ok == 1 {
            builder_write(b, "true")
        } else {
            builder_write(b, "false")
        }
        builder_write(b, ",\"errors\":")
        builder_write(b, int_to_string(rep.errors))
        builder_write(b, ",\"warnings\":")
        builder_write(b, int_to_string(rep.warnings))
        builder_write(b, ",\"text\":\"")
        builder_write(b, json_escape(rep.text))
        builder_write(b, "\"}\n")
        return AdminStateResult { handled: 1, status: 200, body: builder_string(b), servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
    }

    // Request explain dry-run (viewer+).
    if str_eq(path, "/admin/explain") {
        if not str_eq(method, "GET") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let w = parse_config_file(config_path)
        if w.ok == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"config parse failed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut m = query_value(full_path, "method")
        if str_eq(m, "") {
            m = "GET"
        }
        let mut pth = query_value(full_path, "path")
        if str_eq(pth, "") {
            pth = "/"
        }
        let host = query_value(full_path, "host")
        let fe = query_value(full_path, "frontend")
        let er = explain_request(w, fe, m, pth, host)
        let mut b = str_builder()
        builder_write(b, "{\"frontend\":\"")
        builder_write(b, json_escape(er.frontend))
        builder_write(b, "\",\"backend\":\"")
        builder_write(b, json_escape(er.backend))
        builder_write(b, "\",\"denied\":")
        builder_write(b, int_to_string(er.denied))
        builder_write(b, ",\"deny_reason\":\"")
        builder_write(b, json_escape(er.deny_reason))
        builder_write(b, "\",\"text\":\"")
        builder_write(b, json_escape(er.text))
        builder_write(b, "\"}\n")
        return AdminStateResult { handled: 1, status: 200, body: builder_string(b), servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
    }

    // Preview reload: doctor only, no apply (operator+).
    if str_eq(path, "/admin/preview-reload") {
        if not str_eq(method, "POST") {
            if not str_eq(method, "GET") {
                return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
        }
        let w = parse_config_file(config_path)
        if w.ok == 0 {
            let mut eb = str_builder()
            builder_write(eb, "{\"ok\":false,\"would_apply\":false,\"error\":\"")
            builder_write(eb, json_escape(w.error))
            builder_write(eb, "\"}\n")
            return AdminStateResult { handled: 1, status: 200, body: builder_string(eb), servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let rep = doctor_world(w)
        let mut b = str_builder()
        builder_write(b, "{\"ok\":")
        if rep.ok == 1 {
            builder_write(b, "true")
        } else {
            builder_write(b, "false")
        }
        builder_write(b, ",\"would_apply\":")
        if rep.ok == 1 {
            builder_write(b, "true")
        } else {
            builder_write(b, "false")
        }
        builder_write(b, ",\"errors\":")
        builder_write(b, int_to_string(rep.errors))
        builder_write(b, ",\"warnings\":")
        builder_write(b, int_to_string(rep.warnings))
        builder_write(b, ",\"text\":\"")
        builder_write(b, json_escape(rep.text))
        builder_write(b, "\",\"note\":\"preview only — POST /admin/reload to apply\"}\n")
        return AdminStateResult { handled: 1, status: 200, body: builder_string(b), servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
    }

    // GET /admin/waf-rules — sample local signatures
    if str_eq(path, "/admin/waf-rules") {
        if not str_eq(method, "GET") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        return AdminStateResult { handled: 1, status: 200, body: waf_sample_rules_json(), servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
    }

    // POST /admin/waf-mode?frontend=&mode=off|detect|block
    if str_eq(path, "/admin/waf-mode") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let mode = query_value(full_path, "mode")
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if waf_mode_valid(mode) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"mode must be off|detect|block|on\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let fi = find_frontend_idx_admin(frontends, frontend)
        if fi < 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"frontend not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut out_fe = frontends
        let mut fe = out_fe[fi]
        let mut m = mode
        if str_eq(m, "on") {
            m = "block"
        }
        if str_eq(m, "") {
            m = "off"
        }
        fe.waf_mode = m
        out_fe[fi] = fe
        if save_managed_vhosts(config_path, config_dir, out_fe, backends, servers, routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut body = str_builder()
        builder_write(body, "{\"ok\":true,\"action\":\"waf-mode\",\"frontend\":\"")
        builder_write(body, json_escape(frontend))
        builder_write(body, "\",\"mode\":\"")
        builder_write(body, json_escape(m))
        builder_write(body, "\",\"live\":true,\"note\":\"persisted to leba.vhosts.conf; full reload refreshes from file\"}\n")
        log_info_event("admin_action", f"action=waf-mode frontend={frontend} mode={m}")
        return AdminStateResult { handled: 1, status: 200, body: builder_string(body), servers: server_array_clone(servers), frontends: out_fe, backends: backends, routes: routes, acls: acls }
    }

    // POST /admin/server — upsert runtime server into managed vhosts
    if str_eq(path, "/admin/server") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let backend = query_value(full_path, "backend")
        let name = query_value(full_path, "name")
        let addr = query_value(full_path, "addr")
        let weight_s = query_value(full_path, "weight")
        if valid_admin_name(backend) == 0 or valid_admin_name(name) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid backend or name\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_eq(addr, "") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"addr required (host:port)\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut weight = 1
        if not str_eq(weight_s, "") {
            weight = to_int(weight_s)
            if weight <= 0 {
                weight = 1
            }
        }
        let out_backends = admin_vhost_backends(1, backends, backend)
        let mut out_servers = admin_vhost_servers(1, servers, backend, name, addr)
        // Apply weight if server exists
        let mut si = 0
        while si < len(out_servers) {
            if str_eq(out_servers[si].backend, backend) {
                if str_eq(out_servers[si].name, name) {
                    let mut s = out_servers[si]
                    s.weight = weight
                    out_servers[si] = s
                }
            }
            si = si + 1
        }
        if save_managed_vhosts(config_path, config_dir, frontends, out_backends, out_servers, routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut body = str_builder()
        builder_write(body, "{\"ok\":true,\"action\":\"server\",\"backend\":\"")
        builder_write(body, json_escape(backend))
        builder_write(body, "\",\"name\":\"")
        builder_write(body, json_escape(name))
        builder_write(body, "\",\"addr\":\"")
        builder_write(body, json_escape(addr))
        builder_write(body, "\",\"live\":true,\"managed_file\":\"leba.vhosts.conf\"}\n")
        log_info_event("admin_action", f"action=server backend={backend} name={name}")
        return AdminStateResult { handled: 1, status: 200, body: builder_string(body), servers: out_servers, frontends: frontends, backends: out_backends, routes: routes, acls: acls }
    }

    // POST /admin/server-delete
    if str_eq(path, "/admin/server-delete") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let backend = query_value(full_path, "backend")
        let name = query_value(full_path, "name")
        if valid_admin_name(backend) == 0 or valid_admin_name(name) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid backend or name\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut out_servers = make([]Server, 0, len(servers))
        let mut found = 0
        for _, s in range servers {
            if str_eq(s.backend, backend) {
                if str_eq(s.name, name) {
                    found = 1
                    continue
                }
            }
            out_servers = append(out_servers, s)
        }
        if found == 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"server not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if save_managed_vhosts(config_path, config_dir, frontends, backends, out_servers, routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"server-delete\",\"managed_file\":\"leba.vhosts.conf\"}\n",
            servers: out_servers,
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    // Full config reload (operator+). Accept thread applies table swap via full_reload flag.
    if str_eq(path, "/admin/reload") {
        if not str_eq(method, "POST") {
            return AdminStateResult {
                handled: 1,
                status: 405,
                body: "{\"error\":\"method not allowed\"}\n",
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        log_info_event("admin_action", "action=reload status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"reload\",\"note\":\"full config table swap; bind changes require restart\"}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }
    // Live TLS certificate reload (operator+). Accept thread applies tls_server_reload.
    if str_eq(path, "/admin/tls-reload") {
        if not str_eq(method, "POST") {
            return AdminStateResult {
                handled: 1,
                status: 405,
                body: "{\"error\":\"method not allowed\"}\n",
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        // Consistent H3 field contract (0.14): TCP in-place reload; H3 recreates
        // listeners when cert/key paths change (accept thread rebind_h3_listeners).
        let mut h3_n = 0
        for _, feh in range frontends {
            if str_eq(feh.mode, "http") {
                if str_len(feh.tls_cert) > 0 {
                    if str_contains(feh.protocols, "h3") or str_contains(feh.protocols, "http/3") or str_contains(feh.protocols, "quic") {
                        h3_n = h3_n + 1
                    }
                }
            }
        }
        let mut body_tls = str_builder()
        builder_write(body_tls, "{\"ok\":true,\"action\":\"tls-reload\",")
        builder_write(body_tls, "\"tcp_tls_reloaded\":true,")
        builder_write(body_tls, "\"h3_strategy\":\"recreate\",")
        builder_write(body_tls, "\"h3_recreate\":true,")
        // Process restart not required when quiche H3 open works; recreate is in-process.
        builder_write(body_tls, "\"h3_restart_required\":false,")
        builder_write(body_tls, "\"h3_frontends\":")
        builder_write(body_tls, int_to_string(h3_n))
        builder_write(body_tls, ",\"note\":\"TCP TLS reloaded in place; H3 listeners recreated when cert/key paths change\"}\n")
        log_info_event("admin_action", "action=tls-reload status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: builder_string(body_tls),
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }
    // Config read/write (admin only)
    if str_eq(path, "/admin/config") {
        if str_eq(method, "GET") {
            let raw = read_file(config_path)
            // Redact sensitive fields from display
            let mut content = raw
            // Mask auth lines: show user and role but hide password/hash
            let lines = str_split(content, "\n")
            let mut b = str_builder()
            for _, line in range lines {
                if str_has_prefix(str_trim_space(line), "auth ") {
                    // Show: auth <user> ******** <role>
                    builder_write(b, "  auth <credentials redacted>\n")
                } else if str_has_prefix(str_trim_space(line), "auth_hash ") {
                    builder_write(b, "  auth_hash <credentials redacted>\n")
                } else if str_has_prefix(str_trim_space(line), "tls_key ") {
                    builder_write(b, "  tls_key <redacted>\n")
                } else {
                    builder_write(b, line)
                    builder_write(b, "\n")
                }
            }
            let redacted = builder_string(b)
            let mut out = str_builder()
            builder_write(out, "{\"path\":\"")
            builder_write(out, json_escape(config_path))
            builder_write(out, "\",\"content\":\"")
            builder_write(out, json_escape(redacted))
            builder_write(out, "\",\"note\":\"Sensitive fields (auth, tls_key) are redacted. Edit the full file on the server.\"}\n")
            return AdminStateResult {
                handled: 1,
                status: 200,
                body: builder_string(out),
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        // Config write disabled via API for security.
        // Edit the file on the server and run: systemctl restart leba
        return AdminStateResult {
            handled: 1,
            status: 403,
            body: "{\"error\":\"config write disabled via API for security. Edit the file on the server directly.\"}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/vhosts") {
        if not str_eq(method, "GET") {
            return AdminStateResult {
                handled: 1,
                status: 405,
                body: "{\"error\":\"method not allowed\"}\n",
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: admin_vhosts_json(frontends, backends, servers, routes),
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    // NPM-style alias: GET /admin/proxy-hosts
    if str_eq(path, "/admin/proxy-hosts") {
        if not str_eq(method, "GET") {
            return AdminStateResult {
                handled: 1,
                status: 405,
                body: "{\"error\":\"method not allowed\"}\n",
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: admin_vhosts_json(frontends, backends, servers, routes),
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/proxy-host-delete") {
        if not str_eq(method, "POST") {
            return AdminStateResult {
                handled: 1,
                status: 405,
                body: "{\"error\":\"method not allowed\"}\n",
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        let frontend = query_value(full_path, "frontend")
        let domain = query_value(full_path, "domain")
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_domain(domain) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid domain\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let out_routes = remove_host_route(routes, frontend, domain)
        if len(out_routes) == len(routes) {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"proxy host not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if save_managed_vhosts(config_path, config_dir, frontends, backends, servers, out_routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed vhost config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut body = str_builder()
        builder_write(body, "{\"ok\":true,\"action\":\"proxy-host-delete\",\"frontend\":\"")
        builder_write(body, json_escape(frontend))
        builder_write(body, "\",\"domain\":\"")
        builder_write(body, json_escape(domain))
        builder_write(body, "\",\"managed_file\":\"leba.vhosts.conf\"}\n")
        log_info_event("admin_action", "action=proxy-host-delete status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: builder_string(body),
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: out_routes,
            acls: acls
        }
    }

    // POST /admin/vhost-create or /admin/proxy-host — create/update proxy host mapping.
    let mut is_host_create = 0
    if str_eq(path, "/admin/vhost-create") {
        is_host_create = 1
    }
    if str_eq(path, "/admin/proxy-host") {
        is_host_create = 1
    }
    if is_host_create == 1 {
        if not str_eq(method, "POST") {
            return AdminStateResult {
                handled: 1,
                status: 405,
                body: "{\"error\":\"method not allowed\"}\n",
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        let frontend = query_value(full_path, "frontend")
        let domain = query_value(full_path, "domain")
        let backend = query_value(full_path, "backend")
        let server = query_value(full_path, "server")
        let addr = query_value(full_path, "addr")
        let cert = query_value(full_path, "cert")
        let key = query_value(full_path, "key")
        let force_ssl = query_value(full_path, "force_ssl")
        let host_action = query_value(full_path, "action")
        let target = query_value(full_path, "target")
        let code_s = query_value(full_path, "code")
        let ws_s = query_value(full_path, "websocket")
        let enable_s = query_value(full_path, "enable")
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_domain(domain) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid domain\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut enable = 1
        if str_eq(enable_s, "0") or str_eq(enable_s, "false") or str_eq(enable_s, "off") {
            enable = 0
        }
        // Preserve existing websocket when not specified.
        let mut websocket = 1
        let mut host_exists = 0
        for _, rt in range routes {
            if str_eq(rt.frontend, frontend) {
                if str_eq(rt.kind, "host") {
                    if str_eq(rt.value, domain) {
                        host_exists = 1
                        websocket = rt.websocket
                        if str_eq(backend, "") {
                            // keep
                        }
                    }
                }
            }
        }
        if str_eq(ws_s, "0") or str_eq(ws_s, "off") or str_eq(ws_s, "false") {
            websocket = 0
        }
        if str_eq(ws_s, "1") or str_eq(ws_s, "on") or str_eq(ws_s, "true") {
            websocket = 1
        }
        let mut code = to_int(code_s)
        // Upstream only when creating a new proxy host or explicitly providing server+addr.
        let mut need_upstream = 0
        if not str_eq(server, "") and not str_eq(addr, "") and not str_eq(server, "_keep") {
            need_upstream = 1
        }
        if host_exists == 0 {
            if str_eq(host_action, "redirect") or str_eq(host_action, "dead") or enable == 0 {
                need_upstream = 0
            } else {
                need_upstream = 1
            }
        }
        if need_upstream == 1 {
            if valid_admin_name(backend) == 0 {
                return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid backend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
            if valid_admin_name(server) == 0 {
                return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid server\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
            let hp = parse_host_port(addr)
            if str_eq(hp.host, "") {
                return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid server address\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
            if to_int(hp.port) <= 0 {
                return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid server port\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
        }
        if valid_abs_path(cert) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"cert path must be absolute\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_abs_path(key) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"key path must be absolute\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_eq(host_action, "redirect") {
            if str_eq(target, "") {
                return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"redirect target required\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
        }
        let fi = find_frontend_idx_admin(frontends, frontend)
        if fi < 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"frontend not found; create a listener in leba.conf and restart\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut out_frontends = frontend_array_clone(frontends)
        let mut fe = frontend_clone(out_frontends[fi])
        let cert_own = own_string(cert)
        let key_own = own_string(key)
        let domain_own = own_string(domain)
        if not str_eq(cert_own, "") {
            if not str_eq(key_own, "") {
                fe = frontend_upsert_tls_sni(fe, domain_own, cert_own, key_own)
                if str_eq(fe.tls_cert, "") {
                    fe.tls_cert = cert_own
                    fe.tls_key = key_own
                }
            }
        }
        if str_eq(force_ssl, "1") {
            fe.redirect_https = 1
            if fe.redirect_code == 0 {
                fe.redirect_code = 301
            }
        }
        if str_eq(force_ssl, "0") {
            fe.redirect_https = 0
        }
        out_frontends[fi] = fe
        let out_backends = admin_vhost_backends(need_upstream, backends, backend)
        let out_servers = admin_vhost_servers(need_upstream, servers, backend, server, addr)
        let out_routes = upsert_host_route_full(routes, frontend, domain_own, backend, host_action, target, code, websocket, enable)
        if save_managed_vhosts(config_path, config_dir, out_frontends, out_backends, out_servers, out_routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed vhost config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut body = str_builder()
        builder_write(body, "{\"ok\":true,\"action\":\"proxy-host\",\"frontend\":\"")
        builder_write(body, json_escape(frontend))
        builder_write(body, "\",\"domain\":\"")
        builder_write(body, json_escape(domain_own))
        builder_write(body, "\",\"backend\":\"")
        builder_write(body, json_escape(backend))
        builder_write(body, "\",\"enabled\":")
        builder_write(body, int_to_string(enable))
        builder_write(body, ",\"websocket\":")
        builder_write(body, int_to_string(websocket))
        builder_write(body, ",\"host_action\":\"")
        builder_write(body, json_escape(host_action))
        builder_write(body, "\",\"managed_file\":\"leba.vhosts.conf\",\"live\":true,\"force_ssl\":")
        if fe.redirect_https == 1 {
            builder_write(body, "true")
        } else {
            builder_write(body, "false")
        }
        builder_write(body, ",\"tls_reload\":")
        if not str_eq(cert_own, "") {
            if not str_eq(key_own, "") {
                builder_write(body, "true")
            } else {
                builder_write(body, "false")
            }
        } else {
            builder_write(body, "false")
        }
        builder_write(body, ",\"sni\":")
        if not str_eq(cert_own, "") {
            if not str_eq(key_own, "") {
                builder_write(body, "true")
            } else {
                builder_write(body, "false")
            }
        } else {
            builder_write(body, "false")
        }
        builder_write(body, "}\n")
        log_info_event("admin_action", "action=proxy-host status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: builder_string(body),
            servers: out_servers,
            frontends: frontend_array_clone(out_frontends),
            backends: out_backends,
            routes: out_routes,
            acls: acls
        }
    }

    // POST /admin/proxy-host-location — add/update path location under a host
    if str_eq(path, "/admin/proxy-host-location") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let domain = query_value(full_path, "domain")
        let path_p = query_value(full_path, "path")
        let backend = query_value(full_path, "backend")
        let server = query_value(full_path, "server")
        let addr = query_value(full_path, "addr")
        let ws_s = query_value(full_path, "websocket")
        if valid_admin_name(frontend) == 0 or valid_domain(domain) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend or domain\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_eq(path_p, "") or not str_has_prefix(path_p, "/") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"path must start with /\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_admin_name(backend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid backend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut websocket = 1
        if str_eq(ws_s, "0") or str_eq(ws_s, "off") {
            websocket = 0
        }
        let mut out_backends = backend_array_clone(backends)
        let mut out_servers = server_array_clone(servers)
        if not str_eq(server, "") and not str_eq(addr, "") {
            if valid_admin_name(server) == 0 {
                return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid server\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
            out_backends = admin_vhost_backends(1, backends, backend)
            out_servers = admin_vhost_servers(1, servers, backend, server, addr)
        } else {
            out_backends = admin_vhost_backends(1, backends, backend)
        }
        let out_routes = upsert_location_route(routes, frontend, domain, path_p, backend, websocket)
        if save_managed_vhosts(config_path, config_dir, frontends, out_backends, out_servers, out_routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed vhost config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        log_info_event("admin_action", "action=proxy-host-location status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"proxy-host-location\",\"managed_file\":\"leba.vhosts.conf\"}\n",
            servers: out_servers,
            frontends: frontends,
            backends: out_backends,
            routes: out_routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/proxy-host-location-delete") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let domain = query_value(full_path, "domain")
        let path_p = query_value(full_path, "path")
        let out_routes = remove_location_route(routes, frontend, domain, path_p)
        if len(out_routes) == len(routes) {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"location not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if save_managed_vhosts(config_path, config_dir, frontends, backends, servers, out_routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"proxy-host-location-delete\"}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: out_routes,
            acls: acls
        }
    }

    // Host-scoped access list: deny/allow host_src "domain|ip"
    if str_eq(path, "/admin/host-access-list") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let domain = query_value(full_path, "domain")
        let action = query_value(full_path, "action")
        let value = query_value(full_path, "value")
        if valid_admin_name(frontend) == 0 or valid_domain(domain) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend or domain\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_acl_action(action) == 0 or str_eq(value, "") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"action allow|deny and value (IP prefix) required\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let compound = domain + "|" + value
        let out_acls = acl_upsert(acls, frontend, action, "host_src", compound)
        let auth_blob = read_managed_auth_blob(config_dir)
        if save_managed_access(config_path, config_dir, frontends, out_acls, auth_blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save access config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"host-access-list\",\"kind\":\"host_src\"}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: out_acls
        }
    }

    if str_eq(path, "/admin/host-access-list-delete") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let domain = query_value(full_path, "domain")
        let action = query_value(full_path, "action")
        let value = query_value(full_path, "value")
        let compound = domain + "|" + value
        let out_acls = acl_remove(acls, frontend, action, "host_src", compound)
        let auth_blob = read_managed_auth_blob(config_dir)
        if save_managed_access(config_path, config_dir, frontends, out_acls, auth_blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"host-access-list-delete\"}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: out_acls
        }
    }

    // Host-scoped basic auth user: auth_user with host=
    if str_eq(path, "/admin/host-http-auth") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let domain = query_value(full_path, "domain")
        let user = query_value(full_path, "user")
        let pass = query_value(full_path, "pass")
        if valid_admin_name(frontend) == 0 or valid_domain(domain) == 0 or valid_admin_name(user) == 0 or str_eq(pass, "") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"frontend, domain, user, pass required\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        // Encode host-scoped users as: frontend HOST\n  auth_user U P host DOMAIN
        let blob0 = read_managed_auth_blob(config_dir)
        let blob = upsert_auth_user_blob_host(blob0, frontend, domain, user, pass)
        if save_managed_access(config_path, config_dir, frontends, acls, blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"host-http-auth\",\"full_reload\":true}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    // --- Certificates (list / issue via lego / renew) -----------------------
    if str_eq(path, "/admin/certificates") {
        if not str_eq(method, "GET") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let settings = acme_settings_resolve_path(acme_first_webroot(frontends), config_path)
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: acme_list_json(frontends, settings),
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/certificates/issue") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let domain = query_value(full_path, "domain")
        let frontend = query_value(full_path, "frontend")
        let email = query_value(full_path, "email")
        let attach = query_value(full_path, "attach")
        if valid_domain(domain) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid domain\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let fi = find_frontend_idx_admin(frontends, frontend)
        if fi < 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"frontend not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let challenge = query_value(full_path, "challenge")
        let dns_provider = query_value(full_path, "dns_provider")
        let settings = acme_settings_resolve_path(acme_first_webroot(frontends), config_path)
        let result = acme_issue_challenge(settings, domain, email, challenge, dns_provider)
        if result.ok == 0 {
            let st = acme_preflight_http_status(result.error)
            if str_has_prefix(result.error, "code=missing_dns_provider") {
                // ensure 400
            }
            return AdminStateResult {
                handled: 1,
                status: st,
                body: acme_error_json(result.error),
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        let mut out_frontends = frontends
        let mut do_attach = 1
        if str_eq(attach, "0") {
            do_attach = 0
        }
        if do_attach == 1 {
            let mut fe = out_frontends[fi]
            fe = frontend_upsert_tls_sni(fe, domain, result.cert, result.key)
            if str_eq(fe.tls_cert, "") {
                fe.tls_cert = result.cert
                fe.tls_key = result.key
            }
            out_frontends[fi] = fe
            if save_managed_vhosts(config_path, config_dir, out_frontends, backends, servers, routes) == 0 {
                return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"issued but failed to save managed vhost config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
        }
        let mut body = str_builder()
        builder_write(body, "{\"ok\":true,\"action\":\"certificates-issue\",\"domain\":\"")
        builder_write(body, json_escape(domain))
        builder_write(body, "\",\"cert\":\"")
        builder_write(body, json_escape(result.cert))
        builder_write(body, "\",\"key\":\"")
        builder_write(body, json_escape(result.key))
        builder_write(body, "\",\"attached\":")
        if do_attach == 1 {
            builder_write(body, "true")
        } else {
            builder_write(body, "false")
        }
        builder_write(body, ",\"tls_reload\":true}\n")
        log_info_event("admin_action", "action=certificates-issue status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: builder_string(body),
            servers: server_array_clone(servers),
            frontends: out_frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/certificates/renew") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let settings = acme_settings_resolve_path(acme_first_webroot(frontends), config_path)
        let result = acme_renew(settings)
        if result.ok == 0 {
            let st = acme_preflight_http_status(result.error)
            return AdminStateResult {
                handled: 1,
                status: st,
                body: acme_error_json(result.error),
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        log_info_event("admin_action", "action=certificates-renew status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"certificates-renew\",\"tls_reload\":true}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    // --- Access lists ------------------------------------------------------
    if str_eq(path, "/admin/access-lists") {
        if not str_eq(method, "GET") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: acls_json(acls),
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/access-list") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let action = query_value(full_path, "action")
        let kind = query_value(full_path, "kind")
        let value = query_value(full_path, "value")
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_acl_action(action) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"action must be allow or deny\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_acl_kind(kind) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid kind\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_eq(value, "") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"value required\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_contains(value, "\n") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid value\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if find_frontend_idx_admin(frontends, frontend) < 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"frontend not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let out_acls = acl_upsert(acls, frontend, action, kind, value)
        let auth_blob = read_managed_auth_blob(config_dir)
        if save_managed_access(config_path, config_dir, frontends, out_acls, auth_blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed access config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        log_info_event("admin_action", "action=access-list status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"access-list\",\"managed_file\":\"leba.access.conf\"}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: out_acls
        }
    }

    if str_eq(path, "/admin/access-list-delete") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let action = query_value(full_path, "action")
        let kind = query_value(full_path, "kind")
        let value = query_value(full_path, "value")
        let out_acls = acl_remove(acls, frontend, action, kind, value)
        if len(out_acls) == len(acls) {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"rule not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let auth_blob = read_managed_auth_blob(config_dir)
        if save_managed_access(config_path, config_dir, frontends, out_acls, auth_blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed access config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        log_info_event("admin_action", "action=access-list-delete status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"access-list-delete\"}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: out_acls
        }
    }

    // --- App HTTP Basic (managed + full_reload for app_auth_users) ----------
    if str_eq(path, "/admin/http-auth") {
        if str_eq(method, "GET") {
            let blob = read_managed_auth_blob(config_dir)
            return AdminStateResult {
                handled: 1,
                status: 200,
                body: http_auth_json(frontends, blob),
                servers: server_array_clone(servers),
                frontends: frontends,
                backends: backends,
                routes: routes,
                acls: acls
            }
        }
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let user = query_value(full_path, "user")
        let pass = query_value(full_path, "pass")
        let realm = query_value(full_path, "realm")
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_admin_name(user) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid user\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_eq(pass, "") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"pass required\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_contains(pass, " ") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"pass must not contain spaces\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let fi = find_frontend_idx_admin(frontends, frontend)
        if fi < 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"frontend not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut out_frontends = frontends
        let mut fe = out_frontends[fi]
        if not str_eq(realm, "") {
            fe.auth_basic_realm = realm
        } else {
            if str_eq(fe.auth_basic_realm, "") {
                fe.auth_basic_realm = "Restricted"
            }
        }
        out_frontends[fi] = fe
        let blob0 = read_managed_auth_blob(config_dir)
        let blob = upsert_auth_user_blob(blob0, frontend, user, pass)
        if save_managed_access(config_path, config_dir, out_frontends, acls, blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed access config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        log_info_event("admin_action", "action=http-auth status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"http-auth\",\"full_reload\":true,\"note\":\"full config reload applies app auth users\"}\n",
            servers: server_array_clone(servers),
            frontends: out_frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/http-auth-delete") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let user = query_value(full_path, "user")
        let blob0 = read_managed_auth_blob(config_dir)
        let blob = delete_auth_user_blob(blob0, frontend, user)
        if save_managed_access(config_path, config_dir, frontends, acls, blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed access config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        log_info_event("admin_action", "action=http-auth-delete status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"http-auth-delete\",\"full_reload\":true}\n",
            servers: server_array_clone(servers),
            frontends: frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/http-auth-realm") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let realm = query_value(full_path, "realm")
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let fi = find_frontend_idx_admin(frontends, frontend)
        if fi < 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"frontend not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut out_frontends = frontends
        let mut fe = out_frontends[fi]
        fe.auth_basic_realm = realm
        out_frontends[fi] = fe
        let blob = read_managed_auth_blob(config_dir)
        if save_managed_access(config_path, config_dir, out_frontends, acls, blob) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed access config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        log_info_event("admin_action", "action=http-auth-realm status=200")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: "{\"ok\":true,\"action\":\"http-auth-realm\",\"full_reload\":true}\n",
            servers: server_array_clone(servers),
            frontends: out_frontends,
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    if str_eq(path, "/admin/vhost-cert") {
        if not str_eq(method, "POST") {
            return AdminStateResult { handled: 1, status: 405, body: "{\"error\":\"method not allowed\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let frontend = query_value(full_path, "frontend")
        let cert = query_value(full_path, "cert")
        let key = query_value(full_path, "key")
        // Optional hostname/sni → multi-cert SNI entry; omit → default tls_cert/tls_key.
        let mut hostname = query_value(full_path, "hostname")
        if str_eq(hostname, "") {
            hostname = query_value(full_path, "sni")
        }
        if str_eq(hostname, "") {
            hostname = query_value(full_path, "domain")
        }
        if valid_admin_name(frontend) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid frontend\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_abs_path(cert) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"cert path must be absolute\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if valid_abs_path(key) == 0 {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"key path must be absolute\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_eq(cert, "") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"cert required\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if str_eq(key, "") {
            return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"key required\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        if not str_eq(hostname, "") {
            if valid_sni_hostname(hostname) == 0 {
                return AdminStateResult { handled: 1, status: 400, body: "{\"error\":\"invalid sni hostname\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
            }
        }
        let fi = find_frontend_idx_admin(frontends, frontend)
        if fi < 0 {
            return AdminStateResult { handled: 1, status: 404, body: "{\"error\":\"frontend not found\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut out_frontends = frontend_array_clone(frontends)
        let mut fe = frontend_clone(out_frontends[fi])
        let mut sni = 0
        let cert_own = own_string(cert)
        let key_own = own_string(key)
        let host_own = own_string(hostname)
        if not str_eq(host_own, "") {
            fe = frontend_upsert_tls_sni(fe, host_own, cert_own, key_own)
            if str_eq(fe.tls_cert, "") {
                fe.tls_cert = cert_own
                fe.tls_key = key_own
            }
            sni = 1
        } else {
            fe.tls_cert = cert_own
            fe.tls_key = key_own
        }
        out_frontends[fi] = fe
        if save_managed_vhosts(config_path, config_dir, out_frontends, backends, servers, routes) == 0 {
            return AdminStateResult { handled: 1, status: 500, body: "{\"error\":\"failed to save managed vhost config\"}\n", servers: server_array_clone(servers), frontends: frontends, backends: backends, routes: routes, acls: acls }
        }
        let mut body = str_builder()
        builder_write(body, "{\"ok\":true,\"action\":\"vhost-cert\",\"managed_file\":\"leba.vhosts.conf\",\"tls_reload\":true,\"sni\":")
        if sni == 1 {
            builder_write(body, "true,\"hostname\":\"")
            builder_write(body, json_escape(host_own))
            builder_write(body, "\"")
        } else {
            builder_write(body, "false")
        }
        builder_write(body, "}\n")
        return AdminStateResult {
            handled: 1,
            status: 200,
            body: builder_string(body),
            servers: server_array_clone(servers),
            frontends: frontend_array_clone(out_frontends),
            backends: backends,
            routes: routes,
            acls: acls
        }
    }

    let ar = handle_admin(method, path, servers, backends, config_dir)
    return admin_state_from_result(ar, frontends, backends, routes, acls)
}
