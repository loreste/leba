fn TestHeaderRulesRenderAndMerge() {
    let mut rules = make([]HeaderRule, 0, 4)
    rules = append(rules, HeaderRule { direction: "request", action: "set", name: "X-Forwarded-Proto", value: "https" })
    rules = append(rules, HeaderRule { direction: "response", action: "set", name: "X-Frame-Options", value: "DENY" })
    let req_extra, resp_extra = render_header_extras(rules)
    assert(str_contains(req_extra, "X-Forwarded-Proto: https"))
    assert(str_contains(resp_extra, "X-Frame-Options: DENY"))
    let merged = merge_response_extras("\r\nLocation: /", resp_extra)
    assert(str_contains(merged, "Location: /"))
    assert(str_contains(merged, "X-Frame-Options: DENY"))
}

