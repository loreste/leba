fn TestAdminUsersParseRoles() {
    let raw = "frontend stats\n  bind 2\n  mode stats\n  auth admin:secret:admin\n  admin_user viewer viewpass viewer\n  admin_user ops opspass operator\n"
    let w = parse_config_text(raw)
    assert_eq(len(w.admin_users), 3)
    assert_eq_str(w.admin_users[0].pass, "secret")
    assert_eq_str(w.admin_users[0].role, "admin")
    assert_eq_str(w.admin_users[1].user, "viewer")
    assert_eq_str(w.admin_users[1].role, "viewer")
    assert_eq_str(w.admin_users[2].role, "operator")
}

fn TestAdminUsersParseHashesAndFile() {
    let users_path = "/tmp/leba_admin_users_file.txt"
    let _ = write_file(users_path, "fileops sha256:abc123 operator\n")
    let raw = "frontend stats\n  bind 2\n  mode stats\n  auth_hash admin abcdef admin\n  admin_user_hash viewer 123456 viewer\n  admin_users_file /tmp/leba_admin_users_file.txt\n"
    let config_path = "/tmp/leba_admin_users_config.conf"
    let _ = write_file(config_path, raw)
    let w = parse_config_file(config_path)
    assert_eq(w.ok, 1)
    assert_eq(len(w.admin_users), 3)
    assert_eq_str(w.admin_users[0].pass_hash, "abcdef")
    assert_eq_str(w.admin_users[1].role, "viewer")
    assert_eq_str(w.admin_users[2].user, "fileops")
    assert_eq_str(w.admin_users[2].pass_hash, "abc123")
    let _ = remove_file(users_path)
    let _ = remove_file(config_path)
}

