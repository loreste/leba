fn backend_array_clone(src: []Backend) -> []Backend {
    let mut out = make([]Backend, 0, len(src) + 16)
    for _, b in range src {
        out = append(out, backend_clone(b))
    }
    return out
}

fn tls_sni_entry_new(hostname: string, cert: string, key: string) -> TlsSniEntry {
    return TlsSniEntry {
        hostname: own_string(hostname),
        cert: own_string(cert),
        key: own_string(key)
    }
}

fn frontend_new(name: string) -> Frontend {
    return Frontend {
        name: own_string(name),
        bind_host: "",
        bind_port: 0,
        mode: "http",
        maxconn: 0,
        tls_cert: "",
        tls_key: "",
        tls_client_ca: "",
        tls_sni: make([]TlsSniEntry, 0, 0),
        tls_min_13: 0,
        protocols: "http/1.1",
        sticky_cookie: "",
        rate_limit: 0,
        request_body_limit_bytes: 0,
        backend: "",
        xff: 1,
        access_log: 1,
        access_log_file: "",
        root: "",
        acme_webroot: "",
        auth_basic_realm: "",
        waf_mode: "",
        waf_url: "",
        waf_fail: "open",
        waf_timeout_ms: 50,
        redirect_https: 0,
        redirect_code: 301
    }
}

fn frontend_clone(src: Frontend) -> Frontend {
    let mut sni = make([]TlsSniEntry, 0, len(src.tls_sni) + 4)
    for _, e in range src.tls_sni {
        sni = append(sni, tls_sni_entry_new(e.hostname, e.cert, e.key))
    }
    return Frontend {
        name: own_string(src.name),
        bind_host: own_string(src.bind_host),
        bind_port: src.bind_port,
        mode: own_string(src.mode),
        maxconn: src.maxconn,
        tls_cert: own_string(src.tls_cert),
        tls_key: own_string(src.tls_key),
        tls_client_ca: own_string(src.tls_client_ca),
        tls_sni: sni,
        tls_min_13: src.tls_min_13,
        protocols: own_string(src.protocols),
        sticky_cookie: own_string(src.sticky_cookie),
        rate_limit: src.rate_limit,
        request_body_limit_bytes: src.request_body_limit_bytes,
        backend: own_string(src.backend),
        xff: src.xff,
        access_log: src.access_log,
        access_log_file: own_string(src.access_log_file),
        root: own_string(src.root),
        acme_webroot: own_string(src.acme_webroot),
        auth_basic_realm: own_string(src.auth_basic_realm),
        waf_mode: own_string(src.waf_mode),
        waf_url: own_string(src.waf_url),
        waf_fail: own_string(src.waf_fail),
        waf_timeout_ms: src.waf_timeout_ms,
        redirect_https: src.redirect_https,
        redirect_code: src.redirect_code
    }
}

fn frontend_array_clone(src: []Frontend) -> []Frontend {
    let mut out = make([]Frontend, 0, len(src) + 16)
    for _, fe in range src {
        out = append(out, frontend_clone(fe))
    }
    return out
}

// Upsert an SNI cert by hostname (case-sensitive config key; Mako matches case-insensitively).
fn frontend_upsert_tls_sni(fe: Frontend, hostname: string, cert: string, key: string) -> Frontend {
    let mut out = fe
    let mut next = make([]TlsSniEntry, 0, len(out.tls_sni) + 1)
    let mut found = 0
    for _, e in range out.tls_sni {
        if str_eq(e.hostname, hostname) {
            next = append(next, tls_sni_entry_new(hostname, cert, key))
            found = 1
        } else {
            next = append(next, e)
        }
    }
    if found == 0 {
        next = append(next, tls_sni_entry_new(hostname, cert, key))
    }
    out.tls_sni = next
    return out
}

// Stable fingerprint for SNI list changes (recreate TLS server when this differs).
fn frontend_tls_sni_fingerprint(fe: Frontend) -> string {
    let mut b = str_builder()
    for i, e in range fe.tls_sni {
        if i > 0 {
            builder_write(b, ";")
        }
        builder_write(b, e.hostname)
        builder_write(b, "|")
        builder_write(b, e.cert)
        builder_write(b, "|")
        builder_write(b, e.key)
    }
    return builder_string(b)
}

