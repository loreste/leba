fn TestHostLocationAndSelectOrder() {
    let mut routes = make([]Route, 0, 4)
    routes = append(routes, route_new("web", "host", "app.example.com", "app"))
    routes = append(routes, route_location_new("web", "app.example.com", "/api", "api"))
    let ri = select_route_idx(routes, "web", "/api/v1", "app.example.com")
    assert(ri >= 0)
    assert_eq_str(routes[ri].backend, "api")
    let ri2 = select_route_idx(routes, "web", "/home", "app.example.com")
    assert(ri2 >= 0)
    assert_eq_str(routes[ri2].backend, "app")
}

fn TestHostSrcAcl() {
    let mut acls = make([]AclRule, 0, 2)
    acls = append(acls, acl_new("web", "deny", "host_src", "app.example.com|203.0.113."))
    assert_eq(acl_decide_full(acls, "web", "/", "app.example.com", "GET", "203.0.113.5"), 1)
    assert_eq(acl_decide_full(acls, "web", "/", "app.example.com", "GET", "10.0.0.1"), 0)
    assert_eq(acl_decide_full(acls, "web", "/", "other.example.com", "GET", "203.0.113.5"), 0)
}

fn TestProxyHostDisableAndWebsocket() {
    let mut fes = make([]Frontend, 0, 1)
    let mut fe = frontend_new("web")
    fe.mode = "http"
    fe.bind_port = 80
    fes = append(fes, fe)
    let cfg = "/tmp/leba-host-parity.conf"
    let _ = write_file(cfg, "frontend web\n  bind :80\n  mode http\n")
    let ar = handle_admin_state("POST", "/admin/proxy-host",
        "/admin/proxy-host?frontend=web&domain=app.example.com&backend=app&server=s1&addr=127.0.0.1%3A9&websocket=0",
        make([]Server,0,0), fes, make([]Backend,0,0), make([]Route,0,0), make([]AclRule,0,0), cfg, "/tmp")
    assert_eq(ar.status, 200)
    assert_eq(ar.routes[0].websocket, 0)
    let ar2 = handle_admin_state("POST", "/admin/proxy-host",
        "/admin/proxy-host?frontend=web&domain=app.example.com&enable=0",
        ar.servers, ar.frontends, ar.backends, ar.routes, make([]AclRule,0,0), cfg, "/tmp")
    assert_eq(ar2.status, 200)
    assert_eq_str(ar2.routes[0].action, "dead")
    let ar3 = handle_admin_state("POST", "/admin/proxy-host-location",
        "/admin/proxy-host-location?frontend=web&domain=app.example.com&path=%2Fapi&backend=api&server=a1&addr=127.0.0.1%3A8",
        ar2.servers, ar2.frontends, ar2.backends, ar2.routes, make([]AclRule,0,0), cfg, "/tmp")
    assert_eq(ar3.status, 200)
    let mut found = 0
    for _, r in range ar3.routes {
        if str_eq(r.host_match, "app.example.com") {
            if str_eq(r.value, "/api") {
                found = 1
            }
        }
    }
    assert_eq(found, 1)
}

fn TestDns01MissingProvider() {
    let mut s = acme_settings_resolve("")
    s.helper = "lego"
    s.email = "ops@example.com"
    s.webroot = "/tmp/w"
    s.storage = "/tmp/s"
    let r = acme_issue_challenge(s, "app.example.com", "", "dns", "")
    assert_eq(r.ok, 0)
    assert(str_has_prefix(r.error, "code=missing_dns_provider") or str_has_prefix(r.error, "code=missing_helper"))
}
