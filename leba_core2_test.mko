    let raw2 = "frontend secure\n  bind :443\n  mode http\n  tls_cert /tmp/c.crt\n  tls_key /tmp/c.key\n  tls_min 1.2\n  default_backend app\nbackend app\n  server a 127.0.0.1:9 weight 1 check\n"
    let w2 = parse_config_text(raw2)
    assert_eq(w2.frontends[0].tls_min_13, 0)
}

fn TestStatsListenerRebind() {
    let el = evloop_new()
    let mut fe1 = frontend_new("stats")
    fe1.mode = "stats"
    fe1.bind_host = "127.0.0.1"
    // Pick free-ish ports in high range
    let base = 29000 + (now_ms() % 1000)
    fe1.bind_port = base
    let fd1 = frontend_tcp_listen(fe1)
    assert(fd1 >= 0)
    let _ = evloop_add(el, fd1, 1)
    // Same host/port: keep listening (FD number may match)
    let fd2, tls2, srv2, fe2 = rebind_stats_listener(el, fd1, 0, tls_server_new("", ""), fe1, base, fe1, base)
    assert(fd2 >= 0)
    assert_eq(tls2, 0)
    assert_eq(fe2.bind_port, base)
    assert_eq(fd2, fd1)
    // Port change: new listen succeeds; old port is freed (fd numbers may recycle)
    let fe3 = fe1
    let port2 = base + 17
    let fd3, tls3, srv3, fe_out = rebind_stats_listener(el, fd2, 0, srv2, fe2, base, fe3, port2)
    assert(fd3 >= 0)
    assert_eq(fe_out.bind_port, port2)
    assert_eq(tls3, 0)
    // New port accepts connections
    let c = tcp_connect("127.0.0.1", port2)
    assert(c >= 0)
    let _ = tcp_close(c)
    // Old port should be free enough to re-bind
    let mut fe_old = fe1
    fe_old.bind_port = base
    let fd_old = frontend_tcp_listen(fe_old)
    assert(fd_old >= 0)
    let _ = tcp_close(fd_old)
    // Port 0: tear down
    let fd4, tls4, srv4, fe4 = rebind_stats_listener(el, fd3, 0, srv3, fe_out, port2, fe_out, 0)
    assert_eq(fd4, 0 - 1)
    assert_eq(tls4, 0)
    let _ = srv4
    let _ = fe4
    let _ = evloop_close(el)
}

fn TestUdpH3RebindHelpers() {
    assert_eq(runtime_frontend_wants_h3("http/1.1,h2,h3"), 1)
    assert_eq(runtime_frontend_wants_h3("http/1.1,h2"), 0)
    assert_eq(runtime_frontend_wants_h3("quic"), 1)
    let mut fes = make([]Frontend, 0, 3)
    let mut a = frontend_new("web")
    a.mode = "http"
    a.bind_port = 80
    let mut b = frontend_new("sip")
    b.mode = "udp"
    b.bind_port = 5060
    let mut c = frontend_new("db")
    c.mode = "tcp"
    c.bind_port = 3306
    fes = append(fes, a)
    fes = append(fes, b)
    fes = append(fes, c)
    let http = frontends_of_mode(fes, "http")
    let udp = frontends_of_mode(fes, "udp")
    assert_eq(len(http), 1)
    assert_eq(len(udp), 1)
    assert_eq_str(udp[0].name, "sip")

    let mut uls = make([]UdpListener, 0, 1)
    // empty sock placeholder — only frontend name used by filter
    uls = append(uls, UdpListener { frontend: b, sock: game_udp_bind(0), fd: -1 })
    let mut flows = make([]UdpFlow, 0, 2)
    flows = append(flows, UdpFlow { frontend: "sip", backend: "x", call_id: "1", client_peer: 0, server_peer: 0, server_idx: 0, last_seen_ms: 0 })
    flows = append(flows, UdpFlow { frontend: "gone", backend: "x", call_id: "2", client_peer: 0, server_peer: 0, server_idx: 0, last_seen_ms: 0 })
    let kept = filter_udp_flows(flows, uls)
    assert_eq(len(kept), 1)
    assert_eq_str(kept[0].frontend, "sip")
    // cleanup ephemeral bind
    if len(uls) > 0 {
        game_udp_close(uls[0].sock)
    }

    let mut hls = make([]HttpListener, 0, 1)
    hls = append(hls, HttpListener {
        frontend: a,
        fd: -1,
        tls: 0,
        tls_srv: tls_server_new("", ""),
        h3: 0,
        h3_handle: -1
    })
    let mut h3s = make([]H3Listener, 0, 1)
    h3s = append(h3s, H3Listener { frontend: a, handle: 42, fd: 7, frontend_idx: 0 })
    let synced = sync_http_h3_handles(hls, h3s)
    assert_eq(synced[0].h3, 1)
    assert_eq(synced[0].h3_handle, 42)
    let empty_h3 = make([]H3Listener, 0, 0)
    let synced2 = sync_http_h3_handles(synced, empty_h3)
    assert_eq(synced2[0].h3, 0)
    assert_eq(synced2[0].h3_handle, 0 - 1)
}

fn TestFindHttpListenerByNameAndBind() {
    let mut fes = make([]Frontend, 0, 2)
    let mut a = frontend_new("web")
    a.bind_host = "127.0.0.1"
    a.bind_port = 80
    a.mode = "http"
    let mut b = frontend_new("api")
    b.bind_host = "0.0.0.0"
    b.bind_port = 8080
    b.mode = "http"
    let mut listeners = make([]HttpListener, 0, 2)
    listeners = append(listeners, HttpListener {
        frontend: a,
        fd: 10,
        tls: 0,
        tls_srv: tls_server_new("", ""),
        h3: 0,
        h3_handle: 0 - 1
    })
    listeners = append(listeners, HttpListener {
        frontend: b,
        fd: 11,
        tls: 0,
        tls_srv: tls_server_new("", ""),
        h3: 0,
        h3_handle: 0 - 1
    })
    assert_eq(find_http_listener_by_name(listeners, "api"), 1)
    assert_eq(find_http_listener_idx(listeners, "web", "127.0.0.1", 80), 0)
    assert_eq(find_http_listener_idx(listeners, "web", "127.0.0.1", 81), 0 - 1)
    assert_eq_str(frontend_bind_key("127.0.0.1", 443), "127.0.0.1:443")
}

fn TestStickTableGetSetAndPick() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "app"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "app"))
    let mut be = backend_new("app")
    be.stick_on = "src"
    be.stick_size = 100
    be.stick_expire_ms = 60000
    let mut table = make(map[string]string)
    let key = stick_make_key("app", "src", "10.0.0.9")
    let now = 1000000
    let t1, c1, exp1 = stick_table_set(table, key, "b", be.stick_expire_ms, be.stick_size, now, 0)
    assert_eq(c1, 1)
    assert(exp1 > now)
    assert_eq_str(stick_table_get(t1, key, now + 10), "b")
    assert_eq_str(stick_table_get(t1, key, now + 999999), "")
    let si, t2, c2, pline = pick_server_stick(servers, be, "client", "", "", t1, key, now + 10, c1)
    let _ = pline
    assert_eq(si, 1)
    assert_eq(c2, 1)
    let _ = t2
    // Cookie sticky wins over table
    let si2, t3, c3, pline2 = pick_server_stick(servers, be, "client", "SID", "a", t1, key, now + 10, c1)
    assert_eq(si2, 0)
    let _ = t3
    let _ = c3
    let _ = pline2

    // stick_peer_host strips :port so cleartext + TLS keys match by client IP
    assert_eq_str(stick_peer_host("10.0.0.9:54321"), "10.0.0.9")
    assert_eq_str(stick_peer_host("[2001:db8::1]:443"), "2001:db8::1")
    assert_eq_str(stick_peer_host("10.0.0.9"), "10.0.0.9")
    let mut fe = frontend_new("web")
    fe.xff = 0
    assert_eq_str(stick_client_key(fe, "10.0.0.9:9999", ""), "10.0.0.9")
    fe.xff = 1
    assert_eq_str(stick_client_key(fe, "10.0.0.9:9999", "1.2.3.4, 10.0.0.1"), "1.2.3.4")
    // H3 path: no peer IP — fall back to XFF even when xff directive is off
    fe.xff = 0
    assert_eq_str(stick_client_key(fe, "", "9.8.7.6, 10.0.0.1"), "9.8.7.6")
    assert_eq_str(stick_client_key(fe, "", ""), "")
    // H3 stick pick with XFF-derived key
    let h3_key = stick_make_key("app", "src", "9.8.7.6")
    let t_h3, c_h3, exp_h3 = stick_table_set(table, h3_key, "a", be.stick_expire_ms, be.stick_size, now, 0)
    assert(exp_h3 > now)
    let si_h3, t_h3b, c_h3b, pl_h3 = pick_server_stick(servers, be, "client", "", "", t_h3, h3_key, now + 10, c_h3)
    assert_eq(si_h3, 0)
    assert(str_has_prefix(pl_h3, "UPSERT ") or str_eq(pl_h3, ""))
    let _ = t_h3b
    let _ = c_h3b
}

fn TestStickOnSrcParse() {
    let raw = "backend app\n  balance least_conn\n  stick on src\n  stick_table size 5000 expire 10m\n  server a 127.0.0.1:1 weight 1 check\nfrontend web\n  bind 1\n  mode http\n  default_backend app\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq_str(w.backends[0].stick_on, "src")
    assert_eq(w.backends[0].stick_size, 5000)
    assert_eq(w.backends[0].stick_expire_ms, 600000)
}

fn TestPeersConfigAndProtocol() {
    let raw = "peers\n  enabled on\n  name leba-a\n  cluster edge\n  bind 127.0.0.1:19024\n  secret s3cret\n  peer leba-b 127.0.0.1:19025\nfrontend web\n  bind 1\n  mode http\n  default_backend app\nbackend app\n  stick on src\n  server a 127.0.0.1:1 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq(w.peers.enabled, 1)
    assert_eq_str(w.peers.name, "leba-a")
    assert_eq_str(w.peers.cluster, "edge")
    assert_eq(w.peers.bind_port, 19024)
    assert_eq_str(w.peers.bind_host, "127.0.0.1")
    assert_eq_str(w.peers.secret, "s3cret")
    assert_eq(len(w.peers.peers), 1)
    assert_eq_str(w.peers.peers[0].name, "leba-b")
    assert_eq(w.peers.peers[0].port, 19025)
    assert_eq(peers_ready(w.peers), 1)

    let fp1 = peers_config_fingerprint(w.peers)
    let fp2 = peers_config_fingerprint(w.peers)
    assert_eq_str(fp1, fp2)
    let mut peers_b = w.peers
    peers_b.secret = "other"
    assert(not str_eq(fp1, peers_config_fingerprint(peers_b)))

    // Peers listen rebind: open, keep, move port, disable.
    let el = evloop_new()
    let fd1 = rebind_peers_listener(el, 0 - 1, peers_config_new(), w.peers)
    assert(fd1 >= 0)
    let fd2 = rebind_peers_listener(el, fd1, w.peers, w.peers)
    assert_eq(fd2, fd1)
    let mut peers_port = w.peers
    peers_port.bind_port = w.peers.bind_port + 11
    let fd3 = rebind_peers_listener(el, fd2, w.peers, peers_port)
    assert(fd3 >= 0)
    let fd4 = rebind_peers_listener(el, fd3, peers_port, peers_config_new())
    assert_eq(fd4, 0 - 1)
    let _ = evloop_close(el)

    // Apply reload: identity change forces session reset.
    let el2 = evloop_new()
    let listen0 = rebind_peers_listener(el2, 0 - 1, peers_config_new(), w.peers)
    let mut fake = make([]PeerConn, 0, 1)
    fake = append(fake, peer_conn_new(0 - 1, 1, 0))
    let nfd, nconns, force = peers_apply_reload(el2, listen0, w.peers, fake, peers_b)
    assert_eq(force, 1)
    assert_eq(len(nconns), 0)
    assert(nfd >= 0)
    let _ = rebind_peers_listener(el2, nfd, peers_b, peers_config_new())
    let _ = evloop_close(el2)

    let tok = peers_auth_token("s3cret", "leba-b", "edge")
    assert(str_len(tok) == 64)
    let hello = "HELLO leba-b edge " + tok
    let mut table = make(map[string]string)
    let ar = peers_apply_line(hello, w.peers, table, 0, 1000000, "", 0)
    assert_eq(ar.hello_ok, 1)
    assert_eq_str(ar.remote_name, "leba-b")
    assert(str_has_prefix(ar.reply, "OK "))
    assert_eq(ar.close, 0)

    // Bad token closes.
    let bad = peers_apply_line("HELLO leba-b edge deadbeef", w.peers, table, 0, 1000000, "", 0)
    assert_eq(bad.close, 1)

    // Upsert after hello.
    let ar2 = peers_apply_line("UPSERT app|src|1.2.3.4 srv1 2000000", w.peers, table, 0, 1000000, "leba-b", 1)
    assert_eq_str(stick_table_get(ar2.table, "app|src|1.2.3.4", 1500000), "srv1")
    assert_eq(ar2.count, 1)

    // Expired upsert ignored.
    let ar3 = peers_apply_line("UPSERT app|src|9.9.9.9 old 500", w.peers, ar2.table, ar2.count, 1000000, "leba-b", 1)
    assert_eq_str(stick_table_get(ar3.table, "app|src|9.9.9.9", 1000000), "")

    let line = peers_encode_upsert("app|src|1.2.3.4", "srv1", 2000000)
    assert(str_has_prefix(line, "UPSERT "))
    assert(str_contains(line, "srv1"))

    // pick_server_stick emits peer line on local write
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "app"))
    let mut be = backend_new("app")
    be.stick_on = "src"
    be.stick_expire_ms = 60000
    let key = stick_make_key("app", "src", "10.0.0.1")
    let empty = make(map[string]string)
    let si, t2, c2, pl = pick_server_stick(servers, be, "c", "", "", empty, key, 1000000, 0)
    assert_eq(si, 0)
    assert_eq(c2, 1)
    assert(str_has_prefix(pl, "UPSERT "))
    let _ = t2
}

fn TestRedirectAndDeadRouteParse() {
    let raw = "frontend web\n  bind 80\n  mode http\n  route host old.example redirect https://new.example 308\n  route host gone.example dead 410\n  route default -> app\nbackend app\n  server a 127.0.0.1:1 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    let rep = doctor_world(w)
    assert_eq(rep.ok, 1)
    let mut found_r = 0
    let mut found_d = 0
    for _, r in range w.routes {
        if str_eq(r.action, "redirect") {
            assert_eq_str(r.target, "https://new.example")
            assert_eq(r.code, 308)
            found_r = 1
        }
        if str_eq(r.action, "dead") {
            assert_eq(r.code, 410)
            found_d = 1
        }
    }
    assert_eq(found_r, 1)
    assert_eq(found_d, 1)
    let ri = select_route_idx(w.routes, "web", "/", "old.example")
    assert(ri >= 0)
    assert_eq_str(w.routes[ri].action, "redirect")
    let ri2 = select_route_idx(w.routes, "web", "/", "gone.example")
    assert_eq_str(w.routes[ri2].action, "dead")
}

fn TestFullConfigReloadPreservesServerState() {
    let raw = "peers\n  enabled on\n  name leba-a\n  cluster edge\n  bind 127.0.0.1:19024\n  secret s3cret\n  peer leba-b 127.0.0.1:19025\noidc\n  enabled on\n  issuer https://idp.example.com\n  client_id cid\n  client_secret csec\n  redirect_uri https://admin.example.com/oidc/callback\nfrontend web\n  bind 18080\n  mode http\n  route default -> app\nfrontend stats\n  bind 127.0.0.1:18404\n  mode stats\n  auth admin:pass:admin\nbackend app\n  server a 127.0.0.1:1 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    let mut servers = w.servers
    servers = server_conn_delta(servers, 0, 3)
    servers = set_server_drain(servers, 0, 1)
    servers = mark_server_req(servers, 0, 0, 0)
    // mark_server_req increments total_req; force extra counts via loop
    let mut i = 0
    while i < 98 {
        servers = mark_server_req(servers, 0, 0, 0)
        i = i + 1
    }
    let path = "/tmp/leba_reload_test.conf"
    let _ = write_file(path, raw)
    let fr = full_config_reload(path, servers)
    assert_eq(fr.ok, 1)
    assert_eq(fr.servers[0].drain, 1)
    assert_eq(fr.servers[0].total_req, 99)
    assert_eq(fr.servers[0].conns, 3)
    // OIDC + peers travel with FullReload for live apply
    assert_eq(fr.peers.enabled, 1)
    assert_eq_str(fr.peers.name, "leba-a")
    assert_eq(peers_ready(fr.peers), 1)
    assert_eq(fr.oidc.enabled, 1)
    assert_eq_str(fr.oidc.client_id, "cid")
    assert_eq(oidc_ready(fr.oidc), 1)
    assert_eq(fr.stats_port, 18404)
}

fn TestAppBasicAuthParseAndCheck() {
    let raw = "frontend web\n  bind 80\n  mode http\n  auth_basic \"My App\"\n  auth_user alice secret\n  auth_user bob hunter2\n  default_backend app\nbackend app\n  server a 127.0.0.1:1 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq_str(w.frontends[0].auth_basic_realm, "My App")
    assert_eq(len(w.app_auth_users), 2)
    assert_eq(app_basic_auth_ok("", "web", "My App", w.app_auth_users), 0)
    let good = "Basic " + base64_encode("alice:secret")
    assert_eq(app_basic_auth_ok(good, "web", "My App", w.app_auth_users), 1)
    let bad = "Basic " + base64_encode("alice:wrong")
    assert_eq(app_basic_auth_ok(bad, "web", "My App", w.app_auth_users), 0)
    // No realm → always ok
    assert_eq(app_basic_auth_ok("", "web", "", w.app_auth_users), 1)
}

fn TestAcmeWebrootParseAndInherit() {
    let raw = "defaults\n  acme_webroot /var/lib/leba/acme\nfrontend web\n  bind 80\n  mode http\n  default_backend app\nbackend app\n  server a 127.0.0.1:1 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq_str(w.defaults.acme_webroot, "/var/lib/leba/acme")
    assert_eq_str(w.frontends[0].acme_webroot, "/var/lib/leba/acme")
    let raw2 = "defaults\n  acme_webroot /var/lib/leba/acme\nfrontend web\n  bind 80\n  mode http\n  acme_webroot /tmp/challenges\n  default_backend app\nbackend app\n  server a 127.0.0.1:1 weight 1 check\n"
    let w2 = parse_config_text(raw2)
    assert_eq_str(w2.frontends[0].acme_webroot, "/tmp/challenges")
}

fn TestRemoveHostRoute() {
    let mut routes = make([]Route, 0, 2)
    routes = append(routes, route_new("web", "host", "a.example", "app"))
    routes = append(routes, route_new("web", "host", "b.example", "app"))
    routes = append(routes, route_new("web", "default", "", "app"))
    let out = remove_host_route(routes, "web", "a.example")
    assert_eq(len(out), 2)
    let out2 = remove_host_route(out, "web", "missing.example")
    assert_eq(len(out2), 2)
}

fn TestApplyDoneSplitConnVsHealth() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "api"))
    servers = server_conn_delta(servers, 0, 1)
    assert_eq(servers[0].conns, 1)
    // hop0 reserved, hop1 served successfully
    servers = apply_done_servers_conn(0, servers)
    servers = apply_done_servers_health(0, 200, 1, 42, servers)
    assert_eq(servers[0].conns, 0)
    assert_eq(servers[1].conns, 0)
    assert_eq(servers[1].total_req, 1)
    assert_eq(servers[0].total_req, 0)
}
