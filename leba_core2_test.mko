fn TestRedirectHttpsParseAndDoctor() {
    let raw = "frontend redir\n  bind 80\n  mode http\n  redirect https\nfrontend web\n  bind 443\n  mode http\n  default_backend api\nbackend api\n  server a 127.0.0.1:1 weight 1 check\n  server b 127.0.0.1:2 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.frontends[0].redirect_https, 1)
    assert_eq(w.frontends[0].redirect_code, 301)
    let rep = doctor_world(w)
    assert_eq(rep.ok, 1)
}

fn TestRedirectHttpsCustomCode() {
    let raw = "frontend redir\n  bind 80\n  mode http\n  redirect https 308\nbackend api\n  server a 127.0.0.1:1 weight 1 check\n  server b 127.0.0.1:2 weight 1 check\n"
