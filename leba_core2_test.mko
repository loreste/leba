fn TestRetryPlanPicksAlternates() {
    let mut servers = make([]Server, 0, 3)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "api"))
    servers = append(servers, server_new("c", "127.0.0.1", 3, 100, 1, "api"))
    let be = backend_new("api")
    let plan = build_retry_plan(servers, be, "client", "", "", 0, 2)
    assert(plan.n >= 2)
    assert_eq(plan.h0.server_idx, 0)
    assert(plan.h1.server_idx != 0)
}

fn TestDnsPreferIpv4AndResolveFlag() {
    assert_eq_str(dns_prefer_ipv4("::1,127.0.0.1"), "127.0.0.1")
    assert_eq_str(dns_prefer_ipv4("10.0.0.5"), "10.0.0.5")
    assert_eq_str(dns_prefer_ipv4(""), "")
    let ip = dns_resolve_hostname("localhost")
    assert(str_len(ip) > 0)
    let raw = "backend app\n  resolve_interval 5s\n  server a localhost:8080 weight 1 check resolve\nfrontend web\n  bind 1\n  mode http\n  default_backend app\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq(w.servers[0].resolve, 1)
    assert_eq_str(w.servers[0].resolve_name, "localhost")
    assert_eq(w.backends[0].resolve_interval_ms, 5000)
    let resolved = run_dns_resolve(w.servers, w.backends, 1)
    assert(str_len(resolved[0].host) > 0)
    assert(resolved[0].last_resolve_ms > 0)
}

fn TestDnsExpandCreatesMembers() {
    assert_eq_str(dns_member_name("app", "10.0.0.1"), "app-10_0_0_1")
    let ips = dns_split_ips("10.0.0.1,10.0.0.2")
    assert_eq(len(ips), 2)
    let raw = "backend app\n  resolve_interval 5s\n  server svc localhost:8080 weight 50 check resolve expand\nfrontend web\n  bind 1\n  mode http\n  default_backend app\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq(w.servers[0].resolve_expand, 1)
    assert_eq(server_eligible(w.servers[0]), 0)
    let expanded = run_dns_resolve(w.servers, w.backends, 1)
    // template + at least one member for localhost
    assert(len(expanded) >= 2)
    let mut members = 0
    for _, s in range expanded {
        if str_eq(s.resolve_parent, "svc") {
            members = members + 1
            assert(server_eligible(s) == 1 or s.alive == 1)
            assert_eq(s.port, 8080)
            assert_eq(s.weight, 50)
        }
    }
    assert(members >= 1)
}

fn TestDnsSrvParseAndConfig() {
    assert_eq(dns_safe_name("_sip._udp.example.com"), 1)
    assert_eq(dns_safe_name("bad;name"), 0)
    assert_eq(dns_safe_name("a b"), 0)
    let text = "20 1 5060 sip-b.example.com.\n10 5 5061 sip-a.example.com.\n"
    let recs = dns_parse_srv_text(text)
    assert_eq(len(recs), 2)
    assert_eq(recs[0].priority, 20)
    assert_eq(recs[0].port, 5060)
    assert_eq_str(recs[0].target, "sip-b.example.com")
    assert_eq_str(recs[1].target, "sip-a.example.com")
    let sorted = dns_srv_sort(recs)
    assert_eq(sorted[0].priority, 10)
    assert_eq_str(sorted[0].target, "sip-a.example.com")
    assert_eq_str(dns_srv_member_name("sip", "sip-a.example.com", 5061), "sip-sip-a_example_com-5061")

    // Wire-format: build a query and ensure non-empty packet.
    let q = dns_build_srv_query("_sip._udp.example.com", 4660)
    assert(str_len(q) > 20)
    assert_eq(dns_be16_at(q, 0), 4660)
    assert_eq(dns_be16_at(q, 2), 256)

    let raw = "backend sip\n  resolve_interval 5s\n  server sip _sip._udp.example.com:5060 weight 100 check resolve srv\nfrontend web\n  bind 1\n  mode http\n  default_backend sip\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq(w.servers[0].resolve_srv, 1)
    assert_eq(w.servers[0].resolve_expand, 1)
    assert_eq(w.servers[0].resolve, 1)
    assert_eq_str(w.servers[0].resolve_name, "_sip._udp.example.com")
    assert_eq(server_eligible(w.servers[0]), 0)

    // Live SRV against a public name when network allows (skip if empty).
    let live = dns_lookup_srv("_sip._udp.sip.voice.google.com")
    if len(live) > 0 {
        assert(live[0].port > 0)
        assert(str_len(live[0].target) > 0)
        let mut servers = make([]Server, 0, 1)
        let mut tmpl = w.servers[0]
        tmpl.resolve_name = "_sip._udp.sip.voice.google.com"
        tmpl.host = "_sip._udp.sip.voice.google.com"
        servers = append(servers, tmpl)
        let expanded2 = run_dns_resolve(servers, w.backends, 1)
        let mut members = 0
        for _, s in range expanded2 {
            if str_eq(s.resolve_parent, "sip") {
                members = members + 1
                assert(s.port > 0)
            }
        }
        assert(members >= 1)
    }
}

fn TestWafLocalBlocksTraversalAndSqli() {
    let a = waf_local_scan("GET", "/ok", "")
    assert_eq_str(a.action, "allow")
    let b = waf_local_scan("GET", "/x/../../../etc/passwd", "")
    assert_eq_str(b.action, "block")
    let c = waf_local_scan("POST", "/login", "1' or '1'='1")
    assert_eq_str(c.action, "block")
    let d = waf_inspect("detect", "", "open", 50, "GET", "/x/../y", "", "GET /x/../y HTTP/1.1\r\n\r\n")
    assert_eq_str(d.action, "detect")
    let e = waf_inspect("block", "", "open", 50, "GET", "/x/../y", "", "GET /x/../y HTTP/1.1\r\n\r\n")
    assert_eq_str(e.action, "block")
    let f = waf_inspect("off", "", "open", 50, "GET", "/x/../y", "", "")
    assert_eq_str(f.action, "allow")
}

fn TestWafParseAndUrl() {
    let raw = "frontend web\n  bind 80\n  mode http\n  waf block\n  waf_url http://127.0.0.1:8999/v1/inspect\n  waf_fail closed\n  waf_timeout 100ms\n  default_backend app\nbackend app\n  server a 127.0.0.1:1 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq_str(w.frontends[0].waf_mode, "block")
    assert_eq_str(w.frontends[0].waf_url, "http://127.0.0.1:8999/v1/inspect")
    assert_eq_str(w.frontends[0].waf_fail, "closed")
    assert_eq(w.frontends[0].waf_timeout_ms, 100)
    let host, port, path = waf_parse_url("http://10.0.0.5:9000/inspect")
    assert_eq_str(host, "10.0.0.5")
    assert_eq(port, 9000)
    assert_eq_str(path, "/inspect")
}

fn TestTlsMin13Config() {
    let raw = "frontend secure\n  bind :443\n  mode http\n  tls_cert /tmp/c.crt\n  tls_key /tmp/c.key\n  tls_min 1.3\n  default_backend app\nbackend app\n  server a 127.0.0.1:9 weight 1 check\n"
    let w = parse_config_text(raw)
