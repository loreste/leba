// Core domain types for Leba.
pack types

// --- servers & backends ----------------------------------------------------

struct Server {
    name: string
    host: string
    port: int
    weight: int
    maxconn: int
    check: int
    alive: int
    drain: int
    fails: int
    rises: int
    conns: int
    total_req: int
    total_err: int
    total_bytes: int
    last_check_ms: int
    pool: int
    backend: string
    // DNS discovery: 1 = periodically re-resolve resolve_name into host.
    resolve: int
    resolve_name: string
    last_resolve_ms: int
    // 1 = expand A/AAAA into multiple members (template itself is not pickable).
    resolve_expand: int
    // 1 = expand via DNS SRV (implies resolve+expand; ports/targets from SRV answers).
    resolve_srv: int
    // If non-empty, this row is a synthetic child of that template server name.
    resolve_parent: string
}

// One DNS SRV RR (priority, weight, port, target hostname).
struct DnsSrvRecord {
    priority: int
    weight: int
    port: int
    target: string
}

// Accumulator wrapper keeps Mako's array ownership explicit while building
// SRV results; the returned array is copied out before the wrapper is dropped.
struct DnsSrvRecordList {
    rows: []DnsSrvRecord
}

// --- stick-table peers (experimental HA sync) ------------------------------

struct PeerNode {
    name: string
    host: string
    port: int
}

struct PeersConfig {
    // 1 = experimental peers enabled
    enabled: int
    // Local node name (required when enabled)
    name: string
    // Cluster id — HELLO must match
    cluster: string
    bind_host: string
    bind_port: int
    // Shared secret for HELLO HMAC (required when enabled)
    secret: string
    peers: []PeerNode
}

struct PeerConn {
    fd: int
    // Remote node name after successful HELLO
    name: string
    // Accumulated read buffer (line protocol)
    buf: string
    // 1 after mutual HELLO OK
    hello_ok: int
    // 1 if we dialed this peer (vs accepted)
    is_outbound: int
    // Index into PeersConfig.peers for outbound reconnect (-1 for inbound)
    peer_idx: int
}

struct Backend {
    name: string
    balance: string
    servers_file: string
    health_path: string
    health_interval_ms: int
    health_timeout_ms: int
    health_rise: int
    health_fall: int
    connect_timeout_ms: int
    maxconn: int
    retries: int
    rr_idx: int
    // Stick table: "" | "src" (client IP, respects xff). Cookie sticky remains frontend-level.
    stick_on: string
    stick_size: int
    stick_expire_ms: int
    // How often to re-resolve server hostnames marked resolve.
    resolve_interval_ms: int
}

// --- routing & ACL ---------------------------------------------------------

struct Route {
    frontend: string
    kind: string
    value: string
    backend: string
    // "" = reverse-proxy to backend; "redirect" | "dead" = terminal actions (no upstream).
    action: string
    // redirect target URL (absolute or path).
    target: string
    // HTTP status for redirect/dead (0 = default 301 / 404).
    code: int
    // If non-empty, require Host match in addition to kind (path locations under a host).
    host_match: string
    // 1 = allow WebSocket upgrade (default); 0 = 403 on Upgrade: websocket for this route.
    websocket: int
}

struct AclRule {
    frontend: string
    action: string
    kind: string
    value: string
}

struct HeaderRule {
    direction: string
    action: string
    name: string
    value: string
}

struct AdminUser {
    user: string
    pass: string
    pass_hash: string
    role: string
}

// Per-frontend (optional per-host) HTTP Basic credentials for proxied applications.
struct AppAuthUser {
    frontend: string
    user: string
    pass: string
    // Empty = all hosts on this frontend; non-empty = only this Host.
    host: string
}

struct UdpFlow {
    frontend: string
    backend: string
    call_id: string
    client_peer: int
    server_peer: int
    server_idx: int
    last_seen_ms: int
}

// --- frontends -------------------------------------------------------------

// Extra certificate selected by TLS SNI (Mako tls_server_sni_add).
// hostname: exact name or left-most wildcard (e.g. api.example.com, *.example.com).
struct TlsSniEntry {
    hostname: string
    cert: string
    key: string
}

struct Frontend {
    name: string
    bind_host: string
    bind_port: int
    mode: string
    maxconn: int
    tls_cert: string
    tls_key: string
    tls_client_ca: string
    // Additional certs by SNI; default remains tls_cert/tls_key.
    tls_sni: []TlsSniEntry
    // 1 = require TLS 1.3 only (Mako tls_server_new_tls13). 0 = default OpenSSL.
    tls_min_13: int
    protocols: string
    sticky_cookie: string
    rate_limit: int
    request_body_limit_bytes: int
    backend: string
    xff: int
    access_log: int
    access_log_file: string
    root: string
    // Directory of ACME HTTP-01 challenge tokens (token file name = path suffix).
    acme_webroot: string
    // Non-empty = require HTTP Basic for all non-ACME requests on this frontend.
    auth_basic_realm: string
    // WAF: ""|"off"|"detect"|"block"|"on"; optional remote inspect URL.
    waf_mode: string
    waf_url: string
    // "open" (default) or "closed" when remote WAF errors.
    waf_fail: string
    waf_timeout_ms: int
    // 1 = answer with HTTP→HTTPS redirect (no backend). code defaults to 301.
    redirect_https: int
    redirect_code: int
}

struct UdpListener {
    frontend: Frontend
    sock: GameUDP
    fd: int
}

struct HttpListener {
    frontend: Frontend
    fd: int
    tls: int
    tls_srv: TlsServer
    h3: int
    h3_handle: int
}

struct H3Listener {
    frontend: Frontend
    handle: int
    fd: int
    frontend_idx: int
}

struct PendingClient {
    fd: int
    kind: int
    frontend_idx: int
    deadline_ms: int
    buffer: string
    // Requests already completed on this keep-alive connection (0 for new accepts).
    ka_count: int
    // Stable name for rebind remapping (HTTP data plane).
    frontend_name: string
}

// --- global defaults & live stats ------------------------------------------

struct Defaults {
    timeout_client_ms: int
    timeout_server_ms: int
    timeout_connect_ms: int
    maxconn: int
    retries: int
    workers: int
    request_body_limit_bytes: int
    acme_webroot: string
    // lego --path storage (certificates + account).
    acme_storage: string
    // Contact email for ACME registration (or LEBA_ACME_EMAIL).
    acme_email: string
    // ACME helper binary name or absolute path (default "lego", or LEBA_ACME_HELPER).
    acme_helper: string
}

struct LiveStats {
    started_ms: int
    total_req: int
    total_err: int
    total_bytes_in: int
    total_bytes_out: int
    active_conns: int
    denied: int
    rate_limited: int
    retries: int
    last_req_ms: int
    last_latency_ms: int
    max_latency_ms: int
}

struct Config {
    ok: int
    error: string
    defaults: Defaults
    stats_port: int
    stats_user: string
    stats_pass: string
}

fn defaults_new() -> Defaults {
    return Defaults {
        timeout_client_ms: 30000,
        timeout_server_ms: 30000,
        timeout_connect_ms: 5000,
        maxconn: 10000,
        retries: 1,
        workers: 32,
        request_body_limit_bytes: 1048576,
        acme_webroot: "",
        acme_storage: "",
        acme_email: "",
        acme_helper: "lego"
    }
}

fn stats_new() -> LiveStats {
    return LiveStats {
        started_ms: now_ms(),
        total_req: 0,
        total_err: 0,
        total_bytes_in: 0,
        total_bytes_out: 0,
        active_conns: 0,
        denied: 0,
        rate_limited: 0,
        retries: 0,
        last_req_ms: 0,
        last_latency_ms: 0,
        max_latency_ms: 0
    }
}

fn server_new(name: string, host: string, port: int, weight: int, check: int, backend: string) -> Server {
    return Server {
        name: own_string(name),
        host: own_string(host),
        port: port,
        weight: weight,
        maxconn: 0,
        check: check,
        alive: 1,
        drain: 0,
        fails: 0,
        rises: 0,
        conns: 0,
        total_req: 0,
        total_err: 0,
        total_bytes: 0,
        last_check_ms: 0,
        pool: -1,
        backend: own_string(backend),
        resolve: 0,
        resolve_name: "",
        last_resolve_ms: 0,
        resolve_expand: 0,
        resolve_srv: 0,
        resolve_parent: ""
    }
}

fn server_clone(src: Server) -> Server {
    return Server {
        name: own_string(src.name),
        host: own_string(src.host),
        port: src.port,
        weight: src.weight,
        maxconn: src.maxconn,
        check: src.check,
        alive: src.alive,
        drain: src.drain,
        fails: src.fails,
        rises: src.rises,
        conns: src.conns,
        total_req: src.total_req,
        total_err: src.total_err,
        total_bytes: src.total_bytes,
        last_check_ms: src.last_check_ms,
        pool: src.pool,
        backend: own_string(src.backend),
        resolve: src.resolve,
        resolve_name: own_string(src.resolve_name),
        last_resolve_ms: src.last_resolve_ms,
        resolve_expand: src.resolve_expand,
        resolve_srv: src.resolve_srv,
        resolve_parent: own_string(src.resolve_parent)
    }
}

fn server_array_clone(src: []Server) -> []Server {
    // Keep headroom for DNS expansion and admin mutations. Mako's generated
    // append uses realloc; avoiding growth here also avoids freeing the old
    // array header after realloc has already released its backing pointer.
    let mut out = make([]Server, 0, len(src) + 64)
    let mut i = 0
    while i < len(src) {
        out = append(out, server_clone(src[i]))
        i = i + 1
    }
    return out
}

fn dns_srv_record_new(priority: int, weight: int, port: int, target: string) -> DnsSrvRecord {
    return DnsSrvRecord {
        priority: priority,
        weight: weight,
        port: port,
        target: own_string(target)
    }
}

fn dns_srv_record_clone(src: DnsSrvRecord) -> DnsSrvRecord {
    return DnsSrvRecord {
        priority: src.priority,
        weight: src.weight,
        port: src.port,
        target: own_string(src.target)
    }
}

fn dns_srv_record_list_add(acc: DnsSrvRecordList, rec: DnsSrvRecord) -> DnsSrvRecordList {
    let mut out = acc
    out.rows = append(out.rows, dns_srv_record_clone(rec))
    return out
}

fn dns_srv_records_copy(src: []DnsSrvRecord) -> []DnsSrvRecord {
    let mut out = make([]DnsSrvRecord, 0, len(src))
    for i in range len(src) {
        out = append(out, dns_srv_record_clone(src[i]))
    }
    return out
}

fn peer_node_new(name: string, host: string, port: int) -> PeerNode {
    return PeerNode {
        name: own_string(name),
        host: own_string(host),
        port: port
    }
}

