fn TestStatsJsonShape() {
    let st = stats_new()
    let mut fes = make([]Frontend, 0, 1)
    let mut fe = frontend_new("web")
    fe.bind_port = 8080
    fe.mode = "http"
    fe.rate_limit = 10
    fes = append(fes, fe)
    let mut bes = make([]Backend, 0, 1)
    let mut be = backend_new("api")
    be.maxconn = 9
    bes = append(bes, be)
    let mut servers = make([]Server, 0, 1)
    let mut s0 = server_new("s1", "127.0.0.1", 9, 1, 1, "api")
    s0.maxconn = 4
    servers = append(servers, s0)
    let mut routes = make([]Route, 0, 1)
    routes = append(routes, route_new("web", "default", "", "api"))
    let acls = make([]AclRule, 0, 0)
    let mut oidc = oidc_config_new()
    oidc.enabled = 1
    oidc.issuer = "https://idp.example"
    oidc.client_id = "cid"
    oidc.client_secret = "secret"
    oidc.redirect_uri = "https://admin/oidc/callback"
    let mut peers = peers_config_new()
    peers.enabled = 1
    peers.name = "n1"
    peers.cluster = "edge"
    peers.bind_port = 1024
    peers.secret = "s"
    let j = stats_json(st, fes, bes, servers, routes, acls, oidc, peers)
    assert(str_contains(j, "\"version\""))
    assert(str_contains(j, "\"frontends\""))
    assert(str_contains(j, "\"bind_host\""))
    assert(str_contains(j, "\"routes\""))
    assert(str_contains(j, "\"acls\""))
    assert(str_contains(j, "\"servers\""))
    assert(str_contains(j, "0.14.0"))
    assert(str_contains(j, "rate_limit"))
    assert(str_contains(j, "request_body_limit_bytes"))
    assert(str_contains(j, "health_interval_ms"))
    assert(str_contains(j, "servers_file"))
    assert(str_contains(j, "\"maxconn\":9"))
    assert(str_contains(j, "\"maxconn\":4"))
    assert(str_contains(j, "tls_sni"))
    assert(str_contains(j, "stick_on"))
    assert(str_contains(j, "resolve"))
    assert(str_contains(j, "waf_mode"))
    assert(str_contains(j, "protocols"))
    assert(str_contains(j, "\"oidc\""))
    assert(str_contains(j, "\"ready\":1"))
    assert(str_contains(j, "idp.example"))
    assert(str_contains(j, "\"peers\""))
    assert(str_contains(j, "\"cluster\":\"edge\""))
    // Secrets must not appear in stats JSON
    assert(not str_contains(j, "client_secret"))
    assert(not str_contains(j, "\"secret\":"))
}

fn TestWebadminHtmlComplete() {
    let html = webadmin_html()
    assert(str_len(html) > 5000)
    assert(str_contains(html, "Leba Admin"))
    assert(str_contains(html, "function refresh"))
    assert(str_contains(html, "nav('servers')"))
    assert(str_contains(html, "nav('explain')"))
    assert(str_contains(html, "nav('platform')"))
    assert(str_contains(html, "/admin/'+action"))
    assert(str_contains(html, "Drain"))
    assert(str_contains(html, "Ready"))
    assert(str_contains(html, "Explain"))
    assert(str_contains(html, "/stats"))
    assert(str_contains(html, "Control plane"))
    assert(str_contains(html, "Disable"))
    assert(str_contains(html, "Enable"))
    assert(str_contains(html, "sessionStorage"))
    assert(str_contains(html, "lebaAuth"))
    assert(str_contains(html, "Logout"))
    assert(str_contains(html, "reloadServers"))
    assert(str_contains(html, "/admin/reload-servers"))
    assert(str_contains(html, "nav('vhosts')"))
    assert(str_contains(html, "/admin/vhost-create"))
    assert(str_contains(html, "/admin/vhost-cert"))
    assert(str_contains(html, "saveVhost"))
    assert(str_contains(html, "tlsReload"))
    assert(str_contains(html, "fullReload"))
    assert(str_contains(html, "/admin/tls-reload"))
    assert(str_contains(html, "/admin/reload"))
    assert(str_contains(html, "viewPlatform"))
    assert(str_contains(html, "Platform"))
}

fn TestWebadminHasNoAutoMetaRefresh() {
    // SPA uses JS poll; meta refresh would fight interactive admin
    let html = webadmin_html()
    assert(not str_contains(html, "http-equiv=refresh"))
}

fn TestStatsJsonEscapesQuotesInNames() {
    let st = stats_new()
    let fes = make([]Frontend, 0, 0)
    let bes = make([]Backend, 0, 0)
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("q\"q", "h", 1, 1, 1, "b"))
    let routes = make([]Route, 0, 0)
    let acls = make([]AclRule, 0, 0)
    let j = stats_json(st, fes, bes, servers, routes, acls, oidc_config_new(), peers_config_new())
    assert(str_contains(j, "\\\""))
}

fn TestMetricsTextShape() {
    let mut st = stats_new()
    st.total_req = 7
    st.total_err = 1
    st.denied = 2
    st.rate_limited = 3
    let mut fes = make([]Frontend, 0, 1)
    let mut fe = frontend_new("web")
    fe.bind_port = 8080
    fe.mode = "http"
    fes = append(fes, fe)
    let mut bes = make([]Backend, 0, 1)
    let mut be = backend_new("api")
    be.maxconn = 3
    be.stick_on = "src"
    bes = append(bes, be)
    let mut servers = make([]Server, 0, 1)
    let mut s = server_new("s1", "127.0.0.1", 9, 1, 1, "api")
    s.total_req = 4
    s.total_err = 1
    s.total_bytes = 99
    s.conns = 2
    s.maxconn = 5
    servers = append(servers, s)
    let mut oidc = oidc_config_new()
    oidc.enabled = 1
    oidc.client_id = "c"
    oidc.client_secret = "s"
    oidc.redirect_uri = "https://x/cb"
    oidc.issuer = "https://idp"
    let mut peers = peers_config_new()
    peers.enabled = 1
    peers.name = "n"
    peers.secret = "sec"
    peers.bind_port = 9
    let m = metrics_text(st, fes, bes, servers, oidc, peers, 42)
    assert(str_contains(m, "# TYPE leba_requests_total counter"))
    assert(str_contains(m, "leba_requests_total 7"))
    assert(str_contains(m, "leba_denied_total 2"))
    assert(str_contains(m, "leba_rate_limited_total 3"))
    assert(str_contains(m, "leba_frontend_info{frontend=\"web\",mode=\"http\",bind_host=\"\",port=\"8080\"} 1"))
    assert(str_contains(m, "leba_backend_up_servers{backend=\"api\"} 1"))
    assert(str_contains(m, "leba_backend_connections{backend=\"api\"} 2"))
    assert(str_contains(m, "leba_backend_maxconn{backend=\"api\"} 3"))
    assert(str_contains(m, "leba_server_maxconn{backend=\"api\",server=\"s1\"} 5"))
    assert(str_contains(m, "leba_server_pool_idle{backend=\"api\",server=\"s1\"} -1"))
    assert(str_contains(m, "leba_server_pool_open{backend=\"api\",server=\"s1\"} -1"))
    assert(str_contains(m, "leba_server_requests_total{backend=\"api\",server=\"s1\"} 4"))
    assert(str_contains(m, "leba_info{version=\"0.14.0\"} 1"))
    assert(str_contains(m, "leba_waf_blocked_total"))
    assert(str_contains(m, "leba_peers_hello_ok_total"))
    assert(str_contains(m, "leba_stick_entries 42"))
    assert(str_contains(m, "leba_backend_stick{backend=\"api\""))
    assert(str_contains(m, "leba_oidc_ready 1"))
    assert(str_contains(m, "leba_peers_ready 1"))
    assert(str_contains(m, "leba_peers_remotes 0"))
}

fn TestMetricsEscapesLabels() {
    let st = stats_new()
    let mut fes = make([]Frontend, 0, 1)
    fes = append(fes, frontend_new("we\"b"))
    let bes = make([]Backend, 0, 0)
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("s\\1", "h", 1, 1, 1, "b"))
    let m = metrics_text(st, fes, bes, servers, oidc_config_new(), peers_config_new(), 0)
    assert(str_contains(m, "frontend=\"we\\\"b\""))
    assert(str_contains(m, "server=\"s\\\\1\""))
}

fn TestAdminBasicAuthHelpers() {
    assert_eq(admin_auth_required("", ""), 0)
    assert_eq(admin_auth_ok("", "", ""), 0)
    assert_eq(admin_auth_required("admin", "leba"), 1)
    let h = basic_auth_header("admin", "leba")
    assert(str_contains(h, "Basic "))
    assert_eq(admin_auth_ok(h, "admin", "leba"), 1)
    assert_eq(admin_auth_ok("Basic nope", "admin", "leba"), 0)
}

fn TestAdminRbacHelpers() {
    let mut users = make([]AdminUser, 0, 2)
    users = append(users, admin_user_new("view", "pw", "viewer"))
    users = append(users, admin_user_new("ops", "pw", "operator"))
    assert_eq_str(admin_auth_role(basic_auth_header("view", "pw"), users, "", ""), "viewer")
    assert_eq_str(admin_auth_role(basic_auth_header("ops", "pw"), users, "", ""), "operator")
    assert_eq_str(admin_auth_role("Basic nope", users, "", ""), "")
    assert_eq(admin_role_allows("viewer", "viewer"), 1)
    assert_eq(admin_role_allows("viewer", "operator"), 0)
    assert_eq(admin_role_allows("operator", "operator"), 1)
    assert_eq(admin_role_allows("admin", "operator"), 1)
    assert_eq_str(admin_path_required_role("GET", "/stats"), "viewer")
    assert_eq_str(admin_path_required_role("POST", "/admin/drain/api/api1"), "operator")
    assert_eq_str(admin_path_required_role("POST", "/admin/vhost-create"), "operator")
    assert_eq(admin_path_mutates_state("/admin/vhost-create"), 1)
}

fn TestAdminVhostCreateMutatesAndPersists() {
    let mut fes = make([]Frontend, 0, 1)
    let mut fe = frontend_new("web")
    fe.bind_port = 8080
    fe.mode = "http"
    fes = append(fes, fe)
    let bes = make([]Backend, 0, 0)
    let servers = make([]Server, 0, 0)
    let routes = make([]Route, 0, 0)
    let acls = make([]AclRule, 0, 0)

    let mut pb = str_builder()
    builder_write(pb, "/tmp/leba-admin-vhost-")
    builder_write(pb, int_to_string(now_ms()))
    builder_write(pb, ".conf")
    let cfg = builder_string(pb)
    let _ = write_file(cfg, "frontend web\n  bind :8080\n  mode http\n")

    let ar = handle_admin_state(
        "POST",
        "/admin/vhost-create",
        "/admin/vhost-create?frontend=web&domain=example.com&backend=example&server=app1&addr=127.0.0.1%3A9000&cert=%2Ftmp%2Ffullchain.pem&key=%2Ftmp%2Fprivkey.pem",
        servers,
        fes,
        bes,
        routes,
        acls,
        cfg,
        "/tmp"
    )
    assert_eq(ar.handled, 1)
    assert_eq(ar.status, 200)
    assert_eq(len(ar.backends), 1)
    assert_eq(len(ar.servers), 1)
    assert_eq(len(ar.routes), 1)
    assert_eq_str(ar.routes[0].kind, "host")
    assert_eq_str(ar.routes[0].value, "example.com")
    assert_eq_str(ar.servers[0].host, "127.0.0.1")
    assert_eq(ar.servers[0].port, 9000)
    // Per-domain cert is stored as multi-cert SNI; first cert also becomes default when empty.
    assert_eq_str(ar.frontends[0].tls_cert, "/tmp/fullchain.pem")
    assert_eq(len(ar.frontends[0].tls_sni), 1)
    assert_eq_str(ar.frontends[0].tls_sni[0].hostname, "example.com")
    assert_eq_str(ar.frontends[0].tls_sni[0].cert, "/tmp/fullchain.pem")
    assert(str_contains(ar.body, "\"sni\":true"))
    assert(str_contains(read_file(cfg), "include leba.vhosts.conf"))
    assert(str_contains(read_file("/tmp/leba.vhosts.conf"), "route host example.com -> example"))
    assert(str_contains(read_file("/tmp/leba.vhosts.conf"), "tls_sni example.com /tmp/fullchain.pem /tmp/privkey.pem"))

    let w = parse_config_file(cfg)
    assert_eq(w.ok, 1)
    assert_eq(len(w.routes), 1)
    assert_eq(len(w.servers), 1)
    assert_eq_str(w.routes[0].backend, "example")
    // Managed include re-parse picks up tls_sni.
    let mut found_sni = 0
    for _, fe in range w.frontends {
        if str_eq(fe.name, "web") {
            if len(fe.tls_sni) >= 1 {
                found_sni = 1
                assert_eq_str(fe.tls_sni[0].hostname, "example.com")
            }
        }
    }
    assert_eq(found_sni, 1)
}

fn TestConfigTlsSniParse() {
    let raw = "frontend web\n  bind :443\n  mode http\n  tls_cert /tmp/default.crt\n  tls_key /tmp/default.key\n  tls_sni api.example.com /tmp/api.crt /tmp/api.key\n  tls_sni *.example.com /tmp/wild.crt /tmp/wild.key\n  default_backend app\nbackend app\n  server a 127.0.0.1:9 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq(len(w.frontends), 1)
    assert_eq(len(w.frontends[0].tls_sni), 2)
    assert_eq_str(w.frontends[0].tls_sni[0].hostname, "api.example.com")
    assert_eq_str(w.frontends[0].tls_sni[0].cert, "/tmp/api.crt")
    assert_eq_str(w.frontends[0].tls_sni[1].hostname, "*.example.com")
    assert_eq_str(frontend_tls_sni_fingerprint(w.frontends[0]), "api.example.com|/tmp/api.crt|/tmp/api.key;*.example.com|/tmp/wild.crt|/tmp/wild.key")
}

fn TestAdminVhostCertSni() {
    let mut fes = make([]Frontend, 0, 1)
    let mut fe = frontend_new("web")
    fe.bind_port = 443
    fe.mode = "http"
    fe.tls_cert = "/tmp/default.crt"
    fe.tls_key = "/tmp/default.key"
    fes = append(fes, fe)
    let mut pb = str_builder()
    builder_write(pb, "/tmp/leba-admin-sni-")
    builder_write(pb, int_to_string(now_ms()))
    builder_write(pb, ".conf")
    let cfg = builder_string(pb)
    let _ = write_file(cfg, "frontend web\n  bind :443\n  mode http\n  tls_cert /tmp/default.crt\n  tls_key /tmp/default.key\n")
    let ar = handle_admin_state(
        "POST",
        "/admin/vhost-cert",
        "/admin/vhost-cert?frontend=web&hostname=api.example.com&cert=%2Ftmp%2Fapi.crt&key=%2Ftmp%2Fapi.key",
        make([]Server, 0, 0),
        fes,
        make([]Backend, 0, 0),
        make([]Route, 0, 0),
        make([]AclRule, 0, 0),
        cfg,
        "/tmp"
    )
    assert_eq(ar.status, 200)
    assert_eq(len(ar.frontends[0].tls_sni), 1)
    assert_eq_str(ar.frontends[0].tls_sni[0].hostname, "api.example.com")
    assert_eq_str(ar.frontends[0].tls_cert, "/tmp/default.crt")
    assert(str_contains(ar.body, "\"sni\":true"))
    assert_eq(valid_sni_hostname("*.example.com"), 1)
    assert_eq(valid_sni_hostname("a.*.example.com"), 0)
    assert_eq(valid_sni_hostname("api.example.com"), 1)
}

fn TestAdminVhostRejectsBadInput() {
    let mut fes = make([]Frontend, 0, 1)
    fes = append(fes, frontend_new("web"))
    let ar = handle_admin_state(
        "POST",
        "/admin/vhost-create",
        "/admin/vhost-create?frontend=web&domain=bad%2Fhost&backend=be&server=s1&addr=127.0.0.1%3A9000",
        make([]Server, 0, 0),
        fes,
        make([]Backend, 0, 0),
        make([]Route, 0, 0),
        make([]AclRule, 0, 0),
        "/tmp/leba-admin-bad.conf",
        "/tmp"
    )
    assert_eq(ar.handled, 1)
    assert_eq(ar.status, 400)
    assert_eq(len(ar.routes), 0)
}

fn TestAdminVhostsJson() {
    let mut fes = make([]Frontend, 0, 1)
    fes = append(fes, frontend_new("web"))
    let mut bes = make([]Backend, 0, 1)
    bes = append(bes, backend_new("api"))
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("api1", "127.0.0.1", 8080, 1, 1, "api"))
    let mut routes = make([]Route, 0, 1)
    routes = append(routes, route_new("web", "host", "example.com", "api"))
    let ar = handle_admin_state("GET", "/admin/vhosts", "/admin/vhosts", servers, fes, bes, routes, make([]AclRule, 0, 0), "", "/tmp")
    assert_eq(ar.status, 200)
    assert(str_contains(ar.body, "\"domain\":\"example.com\""))
    assert(str_contains(ar.body, "\"managed_file\":\"leba.vhosts.conf\""))
}

fn TestAdminHashAuth() {
    let mut users = make([]AdminUser, 0, 1)
    let mut hb = str_builder()
    builder_write(hb, "leba-kdf-v1:3:abcd1234abcd1234:")
    builder_write(hb, admin_kdf_hash("secret", "abcd1234abcd1234", 3))
    users = append(users, admin_user_hash_new("ops", builder_string(hb), "operator"))
    assert_eq_str(admin_auth_role(basic_auth_header("ops", "secret"), users, "", ""), "operator")
    assert_eq_str(admin_auth_role(basic_auth_header("ops", "wrong"), users, "", ""), "")
    assert_eq_str(admin_hash_kind("leba-kdf-v1:3:abcd1234abcd1234:abc"), "leba-kdf-v1")
    assert_eq(admin_password_matches("secret", sha256("secret")), 1)
}

fn TestAdminArgon2idHashAuthWhenAvailable() {
    if crypto.password_hashing_ok() == 0 {
        return
    }
    let h = crypto.password_hash("secret")
    let mut users = make([]AdminUser, 0, 1)
    users = append(users, admin_user_hash_new("ops", h, "operator"))
    assert_eq_str(admin_hash_kind(h), "argon2id")
    assert_eq(admin_password_matches("secret", h), 1)
    assert_eq(admin_password_matches("wrong", h), 0)
    assert_eq_str(admin_auth_role(basic_auth_header("ops", "secret"), users, "", ""), "operator")
}

fn TestAdminAuditDetailShape() {
    let line = admin_audit_detail("rid1", "ops", "operator", "POST", "/admin/drain/api/api1", 200, "handled")
    assert(str_contains(line, "id=rid1"))
    assert(str_contains(line, "user=\"ops\""))
    assert(str_contains(line, "role=\"operator\""))
    assert(str_contains(line, "method=POST"))
    assert(str_contains(line, "path=\"/admin/drain/api/api1\""))
    assert(str_contains(line, "status=200"))
    assert(str_contains(line, "outcome=handled"))
}

fn TestAdminPathMutatesState() {
    assert_eq(admin_path_mutates_state("/admin/drain/api/api1"), 1)
    assert_eq(admin_path_mutates_state("/admin/reload-servers"), 1)
    assert_eq(admin_path_mutates_state("/admin/servers"), 0)
    assert_eq(admin_path_mutates_state("/stats"), 0)
}

fn TestSessionSecretPrefersStateKey() {
    let a = session_secret("key-a")
    let b = session_secret("key-b")
    assert(not str_eq(a, b))
    let token = session_sign("admin", "operator", "key-a")
    let u, r = session_verify(token, "key-a")
    assert_eq_str(u, "admin")
    assert_eq_str(r, "operator")
    let u2, r2 = session_verify(token, "key-b")
    assert_eq_str(u2, "")
    assert_eq_str(r2, "")
}

fn TestOidcConfigParseAndRoleMap() {
    let raw = "oidc\n  enabled on\n  issuer https://idp.example.com\n  client_id cid\n  client_secret csec\n  redirect_uri https://admin.example.com/oidc/callback\n  jwks_uri https://idp.example.com/jwks\n  verify_jwt on\n  default_role viewer\n  admin_group leba-admins\n  operator_group leba-ops\nfrontend stats\n  bind 127.0.0.1:1\n  mode stats\n  auth admin:pass:admin\n"
    let w = parse_config_text(raw)
    assert_eq(w.ok, 1)
    assert_eq(w.oidc.enabled, 1)
    assert_eq_str(w.oidc.client_id, "cid")
    assert_eq_str(w.oidc.redirect_uri, "https://admin.example.com/oidc/callback")
    assert_eq_str(w.oidc.jwks_uri, "https://idp.example.com/jwks")
    assert_eq(w.oidc.verify_jwt, 1)
    assert_eq(oidc_ready(w.oidc), 1)
    assert_eq(oidc_ready(oidc_config_new()), 0)

    let host, port, path = oidc_parse_https_url("https://idp.example.com/oauth/token")
    assert_eq_str(host, "idp.example.com")
    assert_eq(port, 443)
    assert_eq_str(path, "/oauth/token")

    let claims_admin = "{\"email\":\"a@x.com\",\"groups\":[\"leba-admins\",\"other\"],\"exp\":9999999999,\"iss\":\"https://idp.example.com\",\"aud\":\"cid\"}"
    assert_eq_str(oidc_map_role(w.oidc, claims_admin), "admin")
    assert_eq_str(oidc_pick_user(w.oidc, claims_admin), "a@x.com")
    let claims_ops = "{\"email\":\"o@x.com\",\"groups\":\"leba-ops team\",\"exp\":9999999999}"
    assert_eq_str(oidc_map_role(w.oidc, claims_ops), "operator")
    let claims_view = "{\"email\":\"v@x.com\",\"groups\":[]}"
    assert_eq_str(oidc_map_role(w.oidc, claims_view), "viewer")
    let claims_direct = "{\"leba_role\":\"admin\",\"email\":\"d@x.com\"}"
    assert_eq_str(oidc_map_role(w.oidc, claims_direct), "admin")

    // JWT payload via Mako jwt_payload ( {"sub":"u1"} )
    let mid = "eyJzdWIiOiJ1MSJ9"
    let fake_jwt = "aaa." + mid + ".bbb"
    let payload = oidc_jwt_payload_json(fake_jwt)
    assert(str_contains(payload, "u1"))
    assert_eq_str(payload, jwt_payload(fake_jwt))

    // Soft-trust when no JWKS/PEM material
    let mut soft = oidc_config_new()
    soft.verify_jwt = 1
    soft.jwks_uri = ""
    soft.rsa_public_key = ""
    assert_eq(oidc_verify_id_token(soft, fake_jwt), 1)
    soft.verify_jwt = 0
    assert_eq(oidc_verify_id_token(soft, fake_jwt), 1)
    // Fail closed when rsa_public_key is set but invalid
    soft.verify_jwt = 1
    soft.rsa_public_key = "not-a-pem-key"
    assert_eq(oidc_verify_id_token(soft, fake_jwt), 0)
    soft.rsa_public_key = ""

    let st = oidc_make_state("secret-key")
    assert_eq(oidc_check_state(st, "secret-key"), 1)
    assert_eq(oidc_check_state(st, "other-key"), 0)
    assert_eq(oidc_check_state("bad", "secret-key"), 0)

    let mut cfg = w.oidc
    cfg.authorize_url = "https://idp.example.com/auth"
    let url = oidc_authorize_redirect_url(cfg, "abc.state")
    assert(str_contains(url, "client_id=cid"))
    assert(str_contains(url, "response_type=code"))
    assert(str_contains(url, "state=abc.state"))

    let html = login_page_html(1, 0)
    assert(str_contains(html, "/oidc/login"))
    assert(str_contains(html, "Sign in with SSO"))
    let html2 = login_page_html(1, 1)
    assert(str_contains(html2, "/oidc/login"))
    assert(not str_contains(html2, "loginForm"))
}

fn TestAccessListCrudAndHttpAuthRealm() {
    let mut fes = make([]Frontend, 0, 1)
    let mut fe = frontend_new("web")
    fe.bind_port = 80
    fe.mode = "http"
    fes = append(fes, fe)
    let bes = make([]Backend, 0, 0)
    let servers = make([]Server, 0, 0)
    let routes = make([]Route, 0, 0)
    let acls = make([]AclRule, 0, 0)
    let mut pb = str_builder()
    builder_write(pb, "/tmp/leba-access-")
    builder_write(pb, int_to_string(now_ms()))
    builder_write(pb, ".conf")
    let cfg = builder_string(pb)
    let _ = write_file(cfg, "frontend web\n  bind :80\n  mode http\n")
    let dir = "/tmp"

    let ar = handle_admin_state(
        "POST",
        "/admin/access-list",
        "/admin/access-list?frontend=web&action=deny&kind=src&value=203.0.113.",
        servers, fes, bes, routes, acls, cfg, dir
    )
    assert_eq(ar.handled, 1)
    assert_eq(ar.status, 200)
    assert_eq(len(ar.acls), 1)
    assert_eq_str(ar.acls[0].action, "deny")
    assert_eq_str(ar.acls[0].value, "203.0.113.")
    assert(str_contains(read_file(dir + "/leba.access.conf"), "deny src 203.0.113."))

    let ar2 = handle_admin_state(
        "POST",
        "/admin/access-list-delete",
        "/admin/access-list-delete?frontend=web&action=deny&kind=src&value=203.0.113.",
        servers, ar.frontends, bes, routes, ar.acls, cfg, dir
    )
    assert_eq(ar2.status, 200)
    assert_eq(len(ar2.acls), 0)

    let ar3 = handle_admin_state(
        "POST",
        "/admin/http-auth-realm",
        "/admin/http-auth-realm?frontend=web&realm=Restricted",
        servers, ar2.frontends, bes, routes, ar2.acls, cfg, dir
    )
    assert_eq(ar3.status, 200)
    assert_eq_str(ar3.frontends[0].auth_basic_realm, "Restricted")
    assert(str_contains(ar3.body, "full_reload"))
}

fn TestCertificatesListAndForceSslProxyHost() {
    let mut fes = make([]Frontend, 0, 1)
    let mut fe = frontend_new("web")
    fe.bind_port = 443
    fe.mode = "http"
    fe.tls_cert = "/tmp/def.crt"
    fe.tls_key = "/tmp/def.key"
    fe.acme_webroot = "/tmp/acme-web"
    fes = append(fes, fe)
    let ar = handle_admin_state(
        "GET",
        "/admin/certificates",
        "/admin/certificates",
        make([]Server, 0, 0), fes, make([]Backend, 0, 0), make([]Route, 0, 0), make([]AclRule, 0, 0), "", "/tmp"
    )
    assert_eq(ar.handled, 1)
    assert_eq(ar.status, 200)
    assert(str_contains(ar.body, "\"certificates\""))
    assert(str_contains(ar.body, "\"settings\""))
    assert(str_contains(ar.body, "\"not_after\""))
    assert(str_contains(ar.body, "\"issues\""))
    assert(str_contains(ar.body, "\"ready\""))
    assert(str_contains(ar.body, "/tmp/def.crt"))

    let mut pb = str_builder()
    builder_write(pb, "/tmp/leba-force-")
    builder_write(pb, int_to_string(now_ms()))
    builder_write(pb, ".conf")
    let cfg = builder_string(pb)
    let _ = write_file(cfg, "frontend web\n  bind :80\n  mode http\n")
    let ar2 = handle_admin_state(
        "POST",
        "/admin/proxy-host",
        "/admin/proxy-host?frontend=web&domain=ssl.example.com&backend=app&server=s1&addr=127.0.0.1%3A3000&force_ssl=1",
        make([]Server, 0, 0), fes, make([]Backend, 0, 0), make([]Route, 0, 0), make([]AclRule, 0, 0), cfg, "/tmp"
    )
    assert_eq(ar2.status, 200)
    assert_eq(ar2.frontends[0].redirect_https, 1)
    assert(str_contains(ar2.body, "\"force_ssl\":true"))
}

fn TestAdminPathRolesForCertificatesAndAuth() {
    assert_eq_str(admin_path_required_role("POST", "/admin/certificates/issue"), "admin")
    assert_eq_str(admin_path_required_role("POST", "/admin/certificates/renew"), "admin")
    assert_eq_str(admin_path_required_role("POST", "/admin/http-auth"), "admin")
    assert_eq_str(admin_path_required_role("POST", "/admin/access-list"), "operator")
    assert_eq_str(admin_path_required_role("GET", "/admin/certificates"), "viewer")
    assert_eq_str(admin_path_required_role("DELETE", "/admin/stick-tables"), "operator")
    assert_eq_str(admin_path_required_role("GET", "/admin/stick-tables"), "viewer")
    assert_eq_str(admin_path_required_role("POST", "/admin/waf-mode"), "operator")
    assert_eq_str(admin_path_required_role("GET", "/admin/doctor"), "viewer")
    assert_eq(admin_path_mutates_state("/admin/access-list"), 1)
    assert_eq(admin_path_mutates_state("/admin/certificates/issue"), 1)
}

fn TestTlsReloadH3StrategyFields() {
    let ar = handle_admin_state(
        "POST",
        "/admin/tls-reload",
        "/admin/tls-reload",
        make([]Server, 0, 0),
        make([]Frontend, 0, 0),
        make([]Backend, 0, 0),
        make([]Route, 0, 0),
        make([]AclRule, 0, 0),
        "",
        "/tmp"
    )
    assert_eq(ar.handled, 1)
    assert_eq(ar.status, 200)
    assert(str_contains(ar.body, "\"h3_strategy\":\"recreate\""))
    assert(str_contains(ar.body, "\"tcp_tls_reloaded\":true"))
    assert(str_contains(ar.body, "\"h3_restart_required\":false"))
    assert(str_contains(ar.body, "\"h3_recreate\":true"))
}

fn TestAcmeTokenValidation() {
    assert_eq(acme_token_safe("app.example.com"), 1)
    assert_eq(acme_token_safe("ops@example.com"), 1)
    assert_eq(acme_token_safe("/var/lib/leba/acme"), 1)
    assert_eq(acme_token_safe("bad;rm -rf"), 0)
    assert_eq(acme_token_safe("a b"), 0)
    assert_eq(acme_email_ok("ops@example.com"), 1)
    assert_eq(acme_email_ok("nope"), 0)
}

fn TestAcmePreflightStructuredErrors() {
    let mut s = acme_settings_resolve("")
    s.helper = "lego-definitely-not-installed-xyz"
    s.email = "ops@example.com"
    s.webroot = "/tmp/acme-web"
    s.storage = "/tmp/acme-storage"
    let e = acme_preflight_issue(s, "app.example.com", "")
    assert(str_has_prefix(e, "code=missing_helper"))
    assert_eq(acme_preflight_http_status(e), 400)
    let j = acme_error_json(e)
    assert(str_contains(j, "\"code\":\"missing_helper\""))
    assert(str_contains(j, "\"error\""))

    s.helper = "lego"
    // Even if lego is installed, empty email fails.
    s.email = ""
    let e2 = acme_preflight_issue(s, "app.example.com", "")
    // If lego missing on CI machine, either missing_helper or missing_email is fine for empty email path after helper check order.
    assert(str_has_prefix(e2, "code=missing_helper") or str_has_prefix(e2, "code=missing_email"))

    let e3 = acme_preflight_issue(s, "bad;rm", "ops@example.com")
    assert(str_has_prefix(e3, "code=invalid_domain"))

    let e4 = acme_preflight_renew(s)
    // missing helper or no_certs depending on environment
    assert(str_has_prefix(e4, "code="))
}

fn TestValidAbsPathRejectsTraversal() {
    assert_eq(valid_abs_path(""), 1)
    assert_eq(valid_abs_path("/tmp/ok.pem"), 1)
    assert_eq(valid_abs_path("/tmp/../etc/passwd"), 0)
    assert_eq(valid_abs_path("relative.pem"), 0)
}

