fn TestTraceparentValidationAndExtract() {
    let tp = "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01"
    assert_eq(traceparent_valid(tp), 1)
    assert_eq_str(traceparent_or_new(tp), tp)
    assert_eq_str(traceparent_trace_id(tp), "4bf92f3577b34da6a3ce929d0e0e4736")
    assert_eq_str(traceparent_span_id(tp), "00f067aa0ba902b7")
}

fn TestTraceparentRejectsInvalidAndGenerates() {
    assert_eq(traceparent_valid("not-a-trace"), 0)
    assert_eq(traceparent_valid("00-00000000000000000000000000000000-00f067aa0ba902b7-01"), 0)
    let tp = traceparent_or_new("")
    assert_eq(traceparent_valid(tp), 1)
    assert_eq(str_len(traceparent_trace_id(tp)), 32)
    assert_eq(str_len(traceparent_span_id(tp)), 16)
}

fn TestAccessLogIncludesTrace() {
    let line = access_log_line(
        "GET",
        "/x",
        200,
        "api",
        "s1",
        12,
        99,
        "id1",
        "4bf92f3577b34da6a3ce929d0e0e4736",
        "00f067aa0ba902b7"
    )
    assert(str_contains(line, "trace=4bf92f3577b34da6a3ce929d0e0e4736"))
    assert(str_contains(line, "span=00f067aa0ba902b7"))
}

fn TestRawRequestParserNormalizesAndExtractsHeaders() {
    let raw = "GET   http://example.com:8080/api/v1?q=1   HTTP/1.1\r\nhOsT: edge.example.com\r\nCOOKIE: a=1; LEBAID=s2\r\nTraceParent: 00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01\r\n\r\n"
    let r = parse_raw_request(raw)
    assert_eq(r.ok, 1)
    assert_eq_str(r.method, "GET")
    assert_eq_str(r.path, "/api/v1?q=1")
    assert_eq_str(r.host, "edge.example.com")
    assert_eq_str(cookie_get(r.cookie, "LEBAID"), "s2")
    assert_eq_str(r.traceparent, "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01")
}

fn TestRawRequestParserBodyAndMalformedEdges() {
    let post = "POST /submit HTTP/1.1\r\nHost: h\r\nContent-Length: 7\r\n\r\npayload"
    let r = parse_raw_request(post)
    assert_eq(r.ok, 1)
    assert_eq_str(r.path, "/submit")
    assert_eq_str(r.body, "payload")

    assert_eq(parse_raw_request("GET /incomplete HTTP/1.1\r\nHost: h\r\n").ok, 0)
    assert_eq(parse_raw_request("GET noslash HTTP/1.1\r\nHost: h\r\n\r\n").ok, 0)
    assert_eq(parse_raw_request("GET /missing-version\r\nHost: h\r\n\r\n").ok, 0)
}

