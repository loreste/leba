fn route_new(frontend: string, kind: string, value: string, backend: string) -> Route {
    return Route {
        frontend: own_string(frontend),
        kind: own_string(kind),
        value: own_string(value),
        backend: own_string(backend),
        action: "",
        target: "",
        code: 0,
        host_match: "",
        websocket: 1
    }
}

fn route_location_new(frontend: string, host: string, path_prefix: string, backend: string) -> Route {
    return Route {
        frontend: own_string(frontend),
        kind: "path_prefix",
        value: own_string(path_prefix),
        backend: own_string(backend),
        action: "",
        target: "",
        code: 0,
        host_match: own_string(host),
        websocket: 1
    }
}

fn route_redirect_new(frontend: string, kind: string, value: string, target: string, code: int) -> Route {
    let mut c = code
    if c <= 0 {
        c = 301
    }
    return Route {
        frontend: own_string(frontend),
        kind: own_string(kind),
        value: own_string(value),
        backend: "",
        action: "redirect",
        target: own_string(target),
        code: c,
        host_match: "",
        websocket: 1
    }
}

fn route_dead_new(frontend: string, kind: string, value: string, code: int) -> Route {
    let mut c = code
    if c <= 0 {
        c = 404
    }
    return Route {
        frontend: own_string(frontend),
        kind: own_string(kind),
        value: own_string(value),
        backend: "",
        action: "dead",
        target: "",
        code: c,
        host_match: "",
        websocket: 1
    }
}

