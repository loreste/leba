fn TestAdminReloadServersFile() {
    let servers_path = "/tmp/leba_reload_servers_file.txt"
    let _ = write_file(servers_path, "keep 127.0.0.1:11 weight 2\nnew 127.0.0.1:12 weight 3\n")
    let mut backends = make([]Backend, 0, 1)
    let mut be = backend_new("api")
    be.servers_file = servers_path
    backends = append(backends, be)
    let mut servers = make([]Server, 0, 2)
    let mut keep = server_new("keep", "127.0.0.1", 10, 1, 1, "api")
    keep.total_req = 9
    keep.drain = 1
    servers = append(servers, keep)
    let mut old = server_new("old", "127.0.0.1", 13, 1, 1, "api")
    old.conns = 2
    servers = append(servers, old)
    let r = handle_admin("POST", "/admin/reload-servers", servers, backends, "")
    assert_eq(r.handled, 1)
    assert_eq(r.status, 200)
    assert_eq(len(r.servers), 3)
    assert_eq_str(r.servers[0].name, "keep")
    assert_eq(r.servers[0].total_req, 9)
    assert_eq(r.servers[0].drain, 1)
    assert_eq_str(r.servers[1].name, "new")
    assert_eq_str(r.servers[2].name, "old")
    assert_eq(r.servers[2].drain, 1)
    let r2 = handle_admin("GET", "/admin/reload-servers", servers, backends, "")
    assert_eq(r2.status, 405)
    let _ = remove_file(servers_path)
}

fn TestReadyzLogic() {
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("a", "h", 1, 1, 1, "b"))
    let mut s0 = servers[0]
    s0.drain = 1
    servers[0] = s0
    assert_eq(any_ready(servers), 0)
    let backends = make([]Backend, 0, 0)
    let r = handle_admin("GET", "/readyz", servers, backends, "")
    assert_eq(r.status, 503)
    servers = set_server_drain(servers, 0, 0)
    let r2 = handle_admin("GET", "/readyz", servers, backends, "")
    assert_eq(r2.status, 200)
}

