fn TestTupleChannelDoneRoundTrip() {
    let ch = chan_open[(int, int, int, int, int, int, int, int, int, int)](2)
    let _ = ch.send((1, 502, 3, 4, 99, 0, 7, 1, 0, 2))
    let err, status, conn_si, served_si, bytes, retries, fd, ka, fe, kan = ch.recv()
    assert_eq(err, 1)
    assert_eq(status, 502)
    assert_eq(conn_si, 3)
    assert_eq(served_si, 4)
    assert_eq(bytes, 99)
    assert_eq(retries, 0)
    assert_eq(fd, 7)
    assert_eq(ka, 1)
    assert_eq(fe, 0)
    assert_eq(kan, 2)
}

