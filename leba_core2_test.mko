}

fn TestHealthFallAndRise() {
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("s", "h", 1, 1, 1, "b"))
    servers = apply_probe_result(servers, 0, 0, 2, 2)
    assert_eq(servers[0].alive, 1)
    servers = apply_probe_result(servers, 0, 0, 2, 2)
    assert_eq(servers[0].alive, 0)
    servers = apply_probe_result(servers, 0, 1, 2, 2)
    assert_eq(servers[0].alive, 0)
    servers = apply_probe_result(servers, 0, 1, 2, 2)
    assert_eq(servers[0].alive, 1)
}

