fn TestAdminNonAdminPathNotHandled() {
    let servers = make([]Server, 0, 0)
    let backends = make([]Backend, 0, 0)
    let r = handle_admin("GET", "/stats", servers, backends, "")
    assert_eq(r.handled, 0)
}

fn TestAdminMutationsRequirePost() {
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("s", "h", 1, 1, 1, "b"))
    let backends = make([]Backend, 0, 0)
    let r = handle_admin("GET", "/admin/drain/b/s", servers, backends, "")
    assert_eq(r.handled, 1)
    assert_eq(r.status, 405)
    assert_eq(r.servers[0].drain, 0)
}

fn TestAdminReloadServersFile() {
    let servers_path = "/tmp/leba_reload_servers_file.txt"
    let _ = write_file(servers_path, "keep 127.0.0.1:11 weight 2\nnew 127.0.0.1:12 weight 3\n")
    let mut backends = make([]Backend, 0, 1)
    let mut be = backend_new("api")
    be.servers_file = servers_path
    backends = append(backends, be)
    let mut servers = make([]Server, 0, 2)
    let mut keep = server_new("keep", "127.0.0.1", 10, 1, 1, "api")
    keep.total_req = 9
    keep.drain = 1
    servers = append(servers, keep)
    let mut old = server_new("old", "127.0.0.1", 13, 1, 1, "api")
    old.conns = 2
    servers = append(servers, old)
    let r = handle_admin("POST", "/admin/reload-servers", servers, backends, "")
    assert_eq(r.handled, 1)
    assert_eq(r.status, 200)
    assert_eq(len(r.servers), 3)
    assert_eq_str(r.servers[0].name, "keep")
    assert_eq(r.servers[0].total_req, 9)
    assert_eq(r.servers[0].drain, 1)
    assert_eq_str(r.servers[1].name, "new")
    assert_eq_str(r.servers[2].name, "old")
    assert_eq(r.servers[2].drain, 1)
    let r2 = handle_admin("GET", "/admin/reload-servers", servers, backends, "")
    assert_eq(r2.status, 405)
    let _ = remove_file(servers_path)
}

fn TestReadyzLogic() {
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("a", "h", 1, 1, 1, "b"))
    let mut s0 = servers[0]
    s0.drain = 1
    servers[0] = s0
    assert_eq(any_ready(servers), 0)
    let backends = make([]Backend, 0, 0)
    let r = handle_admin("GET", "/readyz", servers, backends, "")
    assert_eq(r.status, 503)
    servers = set_server_drain(servers, 0, 0)
    let r2 = handle_admin("GET", "/readyz", servers, backends, "")
    assert_eq(r2.status, 200)
}

fn TestLivezAlwaysOk() {
    let servers = make([]Server, 0, 0)
    let backends = make([]Backend, 0, 0)
    let r = handle_admin("GET", "/livez", servers, backends, "")
    assert_eq(r.status, 200)
    assert_eq(r.handled, 1)
}

fn TestServersJsonEscapes() {
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("s\"x", "h", 1, 1, 1, "b"))
    let j = servers_json(servers)
    assert(str_contains(j, "\\\""))
    assert(str_contains(j, "\"servers\""))
}

fn TestAccessLogLineFormat() {
    let line = access_log_line("GET", "/x", 200, "api", "s1", 12, 99, "id1", "", "")
    assert(str_contains(line, "[access]"))
    assert(str_contains(line, "id=id1"))
    assert(str_contains(line, "status=200"))
    assert(str_contains(line, "be=api"))
    assert(str_contains(line, "t=12ms"))
}

fn TestTraceparentValidationAndExtract() {
    let tp = "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01"
    assert_eq(traceparent_valid(tp), 1)
    assert_eq_str(traceparent_or_new(tp), tp)
    assert_eq_str(traceparent_trace_id(tp), "4bf92f3577b34da6a3ce929d0e0e4736")
    assert_eq_str(traceparent_span_id(tp), "00f067aa0ba902b7")
}

fn TestTraceparentRejectsInvalidAndGenerates() {
    assert_eq(traceparent_valid("not-a-trace"), 0)
    assert_eq(traceparent_valid("00-00000000000000000000000000000000-00f067aa0ba902b7-01"), 0)
    let tp = traceparent_or_new("")
    assert_eq(traceparent_valid(tp), 1)
    assert_eq(str_len(traceparent_trace_id(tp)), 32)
    assert_eq(str_len(traceparent_span_id(tp)), 16)
}

fn TestAccessLogIncludesTrace() {
    let line = access_log_line(
        "GET",
        "/x",
        200,
        "api",
        "s1",
        12,
        99,
        "id1",
        "4bf92f3577b34da6a3ce929d0e0e4736",
        "00f067aa0ba902b7"
    )
    assert(str_contains(line, "trace=4bf92f3577b34da6a3ce929d0e0e4736"))
    assert(str_contains(line, "span=00f067aa0ba902b7"))
}

fn TestRawRequestParserNormalizesAndExtractsHeaders() {
    let raw = "GET   http://example.com:8080/api/v1?q=1   HTTP/1.1\r\nhOsT: edge.example.com\r\nCOOKIE: a=1; LEBAID=s2\r\nTraceParent: 00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01\r\n\r\n"
    let r = parse_raw_request(raw)
    assert_eq(r.ok, 1)
    assert_eq_str(r.method, "GET")
    assert_eq_str(r.path, "/api/v1?q=1")
    assert_eq_str(r.host, "edge.example.com")
    assert_eq_str(cookie_get(r.cookie, "LEBAID"), "s2")
    assert_eq_str(r.traceparent, "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01")
}

fn TestRawRequestParserBodyAndMalformedEdges() {
    let post = "POST /submit HTTP/1.1\r\nHost: h\r\nContent-Length: 7\r\n\r\npayload"
    let r = parse_raw_request(post)
    assert_eq(r.ok, 1)
    assert_eq_str(r.path, "/submit")
    assert_eq_str(r.body, "payload")

    assert_eq(parse_raw_request("GET /incomplete HTTP/1.1\r\nHost: h\r\n").ok, 0)
    assert_eq(parse_raw_request("GET noslash HTTP/1.1\r\nHost: h\r\n\r\n").ok, 0)
    assert_eq(parse_raw_request("GET /missing-version\r\nHost: h\r\n\r\n").ok, 0)
}

fn TestWelcomePageShape() {
    let html = leba_welcome_html()
    assert(str_contains(html, "<title>LEBA</title>"))
    assert(str_contains(html, "No backend is configured"))
    assert_eq(leba_should_welcome("/"), 1)
    assert_eq(leba_should_welcome("/index.html"), 1)
    assert_eq(leba_should_welcome("/login"), 0)
}

fn TestUpstreamHttpRequestForwardsTraceparent() {
    let tp = "00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01"
    let req = upstream_http_request_text("POST", "/submit", "payload", "127.0.0.1", 19001, tp)
    assert(str_contains(req, "POST /submit HTTP/1.0\r\n"))
    assert(str_contains(req, "Host: 127.0.0.1:19001\r\n"))
    assert(str_contains(req, "traceparent: 00-4bf92f3577b34da6a3ce929d0e0e4736-00f067aa0ba902b7-01\r\n"))
    assert(str_contains(req, "Content-Length: 7\r\n"))
    assert(str_contains(req, "\r\n\r\npayload"))
}

fn TestRawUpstreamResponseParsing() {
    let raw = "HTTP/1.1 201 Created\r\nContent-Type: text/plain\r\n\r\nhello"
    assert_eq(raw_response_status(raw), 201)
    assert_eq_str(raw_response_body(raw), "hello")
    assert_eq(raw_response_status(""), 0)
    assert_eq_str(raw_http_reason(413), "Payload Too Large")
}

fn TestSipCallIdExtraction() {
    let msg = "INVITE sip:bob@example.com SIP/2.0\r\nVia: SIP/2.0/TCP client;branch=z9hG4bK\r\nCall-ID: abc-123@example.com\r\nCSeq: 1 INVITE\r\n\r\n"
    assert_eq_str(sip_call_id(msg), "abc-123@example.com")
    let compact = "INVITE sip:bob@example.com SIP/2.0\r\ni: compact-42\r\n\r\n"
    assert_eq_str(sip_call_id(compact), "compact-42")
}

fn TestSipCallIdBalanceIsStable() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("s1", "h", 1, 1, 1, "sip"))
    servers = append(servers, server_new("s2", "h", 2, 1, 1, "sip"))
    let mut be = backend_new("sip")
    be.balance = "sip_call_id"
    let a = pick_server(servers, be, "call-abc", "", "")
    let b = pick_server(servers, be, "call-abc", "", "")
    assert_eq(a, b)
}

fn TestHealthFallAndRise() {
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("s", "h", 1, 1, 1, "b"))
    servers = apply_probe_result(servers, 0, 0, 2, 2)
    assert_eq(servers[0].alive, 1)
    servers = apply_probe_result(servers, 0, 0, 2, 2)
    assert_eq(servers[0].alive, 0)
    servers = apply_probe_result(servers, 0, 1, 2, 2)
    assert_eq(servers[0].alive, 0)
    servers = apply_probe_result(servers, 0, 1, 2, 2)
    assert_eq(servers[0].alive, 1)
}

fn TestSampleConfigDoctor() {
    let w = parse_config_file("configs/leba.conf")
    if w.ok == 0 {
        assert(true)
        return
    }
    let rep = doctor_world(w)
    assert_eq(rep.ok, 1)
    assert(len(w.frontends) >= 1)
}

fn TestPackDoneRoundTrip() {
    let v = pack_done(1, 502, 3, 99)
    assert_eq(unpack_done_err(v), 1)
    assert_eq(unpack_done_status(v), 502)
    assert_eq(unpack_done_si(v), 3)
    assert_eq(unpack_done_bytes(v), 99)
    assert_eq(unpack_done_retries(v), 0)
}

fn TestPackDoneRetryRoundTripAndStats() {
    let v = pack_done_retry(0, 200, 1, 123, 2)
    assert_eq(unpack_done_err(v), 0)
    assert_eq(unpack_done_status(v), 200)
    assert_eq(unpack_done_si(v), 1)
    assert_eq(unpack_done_bytes(v), 123)
    assert_eq(unpack_done_retries(v), 2)
    let servers = make([]Server, 0, 0)
    let st = apply_done(v, servers, stats_new())
    assert_eq(st.retries, 2)
}

fn TestWorkersDefaultAndConfig() {
    let d = defaults_new()
    assert(d.workers >= 1)
    let raw = "defaults\n  workers 16\nfrontend web\n  bind 1\n  mode http\n  default_backend api\nbackend api\n  server a 127.0.0.1:1 weight 1 check\n  server b 127.0.0.1:2 weight 1 check\n"
    let w = parse_config_text(raw)
    assert_eq(w.defaults.workers, 16)
}

fn TestCliHttpRequestIncludesBasicAuth() {
    let req = cli_http_request_text("GET", "/stats", "127.0.0.1", "admin:leba")
    assert(str_contains(req, "GET /stats HTTP/1.0"))
    assert(str_contains(req, "Authorization: Basic "))
    assert(str_contains(req, base64_encode("admin:leba")))
}

fn TestCliHttpBodyAndAdminPath() {
    let raw = "HTTP/1.0 200 OK\r\nContent-Type: application/json\r\n\r\n{\"ok\":true}\n"
    assert_eq_str(cli_http_body(raw), "{\"ok\":true}\n")
