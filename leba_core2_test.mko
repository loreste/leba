fn TestIpHashStable() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "api"))
    let mut be = backend_new("api")
    be.balance = "ip_hash"
    assert_eq(pick_server(servers, be, "10.0.0.5", "", ""), pick_server(servers, be, "10.0.0.5", "", ""))
}

fn TestRoundRobinAdvances() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "api"))
    let mut be = backend_new("api")
    be.balance = "round_robin"
    be.rr_idx = 0
    let i0 = pick_server(servers, be, "c", "", "")
    be = next_rr(be)
    let i1 = pick_server(servers, be, "c", "", "")
    be = next_rr(be)
    let i2 = pick_server(servers, be, "c", "", "")
    assert_eq(i0, 0)
    assert_eq(i1, 1)
    assert_eq(i2, 0)
}

fn TestServerEligible() {
    let mut s = server_new("a", "h", 1, 1, 1, "b")
    assert_eq(server_eligible(s), 1)
    s.drain = 1
    assert_eq(server_eligible(s), 0)
    s.drain = 0
    s.alive = 0
    assert_eq(server_eligible(s), 0)
    s.alive = 1
    s.maxconn = 2
    s.conns = 2
    assert_eq(server_eligible(s), 0)
    s.conns = 1
    assert_eq(server_eligible(s), 1)
}

fn TestAllDrainedFailsClosed() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "api"))
    let mut s0 = servers[0]
    s0.drain = 1
    servers[0] = s0
    let mut s1 = servers[1]
    s1.drain = 1
    servers[1] = s1
    let be = backend_new("api")
    assert_eq(pick_server(servers, be, "c", "", ""), -1)
}

fn TestMaxconnSaturationHelpers() {
    let mut servers = make([]Server, 0, 3)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "api"))
    servers = append(servers, server_new("w", "127.0.0.1", 3, 100, 1, "web"))
    let mut s0 = servers[0]
    s0.conns = 1
    servers[0] = s0
    let mut s1 = servers[1]
    s1.conns = 2
    servers[1] = s1
    let mut s2 = servers[2]
    s2.conns = 4
    servers[2] = s2

    let mut be = backend_new("api")
    be.maxconn = 3
    assert_eq(backend_conn_count(servers, "api"), 3)
    assert_eq(backend_at_maxconn(servers, be), 1)
    be.maxconn = 4
    assert_eq(backend_at_maxconn(servers, be), 0)

    let mut fe = frontend_new("web")
    fe.maxconn = 7
    assert_eq(total_conn_count(servers), 7)
    assert_eq(frontend_at_maxconn(servers, fe), 1)
    fe.maxconn = 8
    assert_eq(frontend_at_maxconn(servers, fe), 0)
}

fn TestPickSkipsServerAtMaxconn() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("a", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("b", "127.0.0.1", 2, 100, 1, "api"))
    let mut s0 = servers[0]
    s0.maxconn = 1
    s0.conns = 1
    servers[0] = s0
    let mut be = backend_new("api")
    be.balance = "round_robin"
    assert_eq(pick_server(servers, be, "c", "", ""), 1)
    assert_eq(pick_server(servers, be, "c", "LEBAID", "a"), 1)
}

fn TestRateWouldDeny() {
    let mut b = rate_new("web", 2)
    b.tokens = 0
    b.last_ms = now_ms()
    assert_eq(rate_would_deny(b), 1)
    b.tokens = 2
    assert_eq(rate_would_deny(b), 0)
}

fn TestRateTakeDecrements() {
    let mut b = rate_new("web", 5)
    b.tokens = 3
    b.last_ms = now_ms()
    let a = rate_take(b)
    assert_eq(a.tokens, 2)
}

fn TestRatePartialSecondRefill() {
    let mut b = rate_new("web", 10)
    b.tokens = 0
    b.last_ms = now_ms() - 600
    assert_eq(rate_would_deny(b), 0)
    let a = rate_take(b)
    assert(a.tokens >= 4)
    assert(a.tokens <= 6)
}

fn TestRateCarriesFractionalTime() {
    let mut b = rate_new("web", 3)
    b.tokens = 0
    b.last_ms = now_ms() - 500
    let a = rate_refill(b)
    assert_eq(a.tokens, 1)
    let elapsed_left = now_ms() - a.last_ms
    assert(elapsed_left >= 100)
}

fn TestRateDisabledNeverDenies() {
    let mut b = rate_new("web", 1)
    b.rate_per_sec = 0
    b.tokens = 0
    assert_eq(rate_would_deny(b), 0)
}

fn TestRateFind() {
    let mut fes = make([]Frontend, 0, 2)
    let mut f = frontend_new("a")
    f.rate_limit = 10
    fes = append(fes, f)
    let mut f2 = frontend_new("b")
    f2.rate_limit = 0
    fes = append(fes, f2)
    let buckets = rate_init_all(fes)
    assert_eq(len(buckets), 1)
    assert(rate_find(buckets, "a") >= 0)
    assert_eq(rate_find(buckets, "b"), -1)
}

fn TestDoctorFailsMissingBackend() {
    let raw = "frontend web\n  bind 8080\n  mode http\n  route default -> missing\nbackend empty\n  balance round_robin\n"
    let w = parse_config_text(raw)
    let rep = doctor_world(w)
    assert_eq(rep.ok, 0)
    assert(rep.errors >= 2)
}

