fn TestDoctorRejectsUnknownAdminRole() {
    let raw = "frontend web\n  bind 1\n  mode http\n  default_backend api\nfrontend stats\n  bind 2\n  mode stats\n  admin_user alice secret root\nbackend api\n  server a 127.0.0.1:1 weight 1 check\n  server b 127.0.0.1:2 weight 1 check\n"
    let w = parse_config_text(raw)
    let rep = doctor_world(w)
    assert_eq(rep.ok, 0)
    assert(str_contains(rep.text, "unknown role"))
