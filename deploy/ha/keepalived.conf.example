# Example keepalived for Leba active/standby.
# Adjust interface, VIP, and auth. Run as root on both nodes.
#
# /etc/keepalived/keepalived.conf

global_defs {
    router_id leba_ha
}

vrrp_script chk_leba {
    script "/usr/local/bin/leba-healthcheck.sh"
    interval 2
    weight -30
    fall 2
    rise 2
}

vrrp_instance VI_LEBA {
    state BACKUP                 # MASTER on primary node
    interface eth0
    virtual_router_id 51
    priority 100                 # 150 on primary
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass change_me
    }
    virtual_ipaddress {
        10.0.0.50/24
    }
    track_script {
        chk_leba
    }
}
