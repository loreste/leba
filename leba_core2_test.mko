}

fn TestCliHashPasswordShape() {
    let h = admin_kdf_hash("secret", "salt-1234567890", 3)
    assert_eq(str_len(h), 64)
}

fn TestCliAddressNormalizationForNat() {
    assert_eq_str(cli_clean_addr("http://edge.example.com:18404/admin/servers"), "edge.example.com:18404")
    assert_eq_str(cli_addr_host("http://edge.example.com:18404/admin/servers"), "edge.example.com")
    assert_eq(cli_addr_port("http://edge.example.com:18404/admin/servers"), 18404)
    assert_eq_str(cli_addr_host("edge.example.com"), "edge.example.com")
    assert_eq(cli_addr_port("edge.example.com"), 18404)
}
