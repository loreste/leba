fn TestDoctorReportsServersFileParseFailure() {
    let config_path = "/tmp/leba_missing_servers_file.conf"
    let _ = write_file(config_path, "frontend web\n  bind 1\n  mode http\n  default_backend api\nbackend api\n  servers_file /tmp/leba_no_such_servers_file.txt\n")
    let w = parse_config_file(config_path)
    let rep = doctor_world(w)
    assert_eq(rep.ok, 0)
    assert(str_contains(rep.text, "servers_file unreadable"))
    let _ = remove_file(config_path)
}

fn TestExplainDeny() {
    let raw = "frontend web\n  bind 8080\n  mode http\n  deny path_prefix /secret\n  route default -> api\nbackend api\n  server s1 127.0.0.1:9 weight 1 check\n"
    let w = parse_config_text(raw)
    let ex = explain_request(w, "", "GET", "/secret/x", "h")
    assert_eq(ex.denied, 1)
    assert_eq(ex.ok, 0)
}

fn TestExplainRoute() {
    let raw = "frontend web\n  bind 8080\n  mode http\n  route path_prefix /api -> api\n  route default -> web\nbackend api\n  server a 127.0.0.1:1 weight 1 check\nbackend web\n  server w 127.0.0.1:2 weight 1 check\n"
    let w = parse_config_text(raw)
    let ex = explain_request(w, "", "GET", "/api/z", "h")
    assert_eq(ex.ok, 1)
    assert_eq_str(ex.backend, "api")
}

fn TestExplainUnknownBackend() {
    let raw = "frontend web\n  bind 1\n  mode http\n  route default -> missing\nbackend other\n  server a 127.0.0.1:1 weight 1 check\n"
    let w = parse_config_text(raw)
    let ex = explain_request(w, "", "GET", "/", "h")
    assert_eq(ex.ok, 0)
}

fn TestPathPartSplit() {
    assert_eq_str(path_part("/admin/drain/api/api1", 1), "admin")
    assert_eq_str(path_part("/admin/drain/api/api1", 2), "drain")
    assert_eq_str(path_part("/admin/drain/api/api1", 3), "api")
    assert_eq_str(path_part("/admin/drain/api/api1", 4), "api1")
    assert_eq_str(path_part("/admin/drain/api/api1", 99), "")
}

fn TestAdminDrainReady() {
    let mut servers = make([]Server, 0, 2)
    servers = append(servers, server_new("api1", "127.0.0.1", 1, 100, 1, "api"))
    servers = append(servers, server_new("api2", "127.0.0.1", 2, 100, 1, "api"))
    let backends = make([]Backend, 0, 0)
    let r = handle_admin("POST", "/admin/drain/api/api1", servers, backends, "")
    assert_eq(r.handled, 1)
    assert_eq(r.status, 200)
    assert_eq(r.servers[0].drain, 1)
    let r2 = handle_admin("POST", "/admin/ready/api/api1", r.servers, backends, "")
    assert_eq(r2.servers[0].drain, 0)
    assert_eq(r2.servers[0].alive, 1)
}

fn TestAdminDisableEnable() {
    let mut servers = make([]Server, 0, 1)
    servers = append(servers, server_new("s", "h", 1, 1, 1, "b"))
    let backends = make([]Backend, 0, 0)
    let r = handle_admin("POST", "/admin/disable/b/s", servers, backends, "")
    assert_eq(r.servers[0].alive, 0)
    let r2 = handle_admin("POST", "/admin/enable/b/s", r.servers, backends, "")
    assert_eq(r2.servers[0].alive, 1)
}

